---
interface Props {
  version: string
  date: string
}

const { version, date } = Astro.props
---

<article
  class="relative my-20 flex flex-col justify-center gap-x-14 border-b border-border md:flex-row"
>
  <div class="mb-4 md:mb-10 md:w-1/3">
    <div
      class="sticky top-24 flex items-center space-x-2 md:block md:space-x-0 md:space-y-1.5"
    >
      <span
        class="inline-flex items-center rounded-lg bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10 dark:bg-indigo-500/20 dark:text-indigo-300 dark:ring-indigo-400/20"
      >
        {version}
      </span>
      <span
        class="block whitespace-nowrap text-sm text-muted-foreground"
      >
        {date}
      </span>
    </div>
  </div>
  <div
    class="changelog-body mb-12 md:w-2/3"
  >
    <slot />
  </div>
</article>

<style>
  .changelog-body :global(h2) {
    margin-bottom: 1rem;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .changelog-body :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .changelog-body :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.75;
    color: var(--color-muted-foreground);
  }
  .changelog-body :global(ul) {
    margin-bottom: 2rem;
    margin-left: 1.75rem;
    list-style: "– ";
    line-height: 2;
    color: var(--color-muted-foreground);
  }
  .changelog-body :global(ul > li) {
    padding-left: 0.25rem;
  }
  .changelog-body :global(b),
  .changelog-body :global(strong) {
    font-weight: 600;
    color: var(--color-foreground);
  }
  .changelog-body :global(a) {
    color: oklch(0.52 0.22 270);
    font-weight: 500;
    text-underline-offset: 3px;
  }
  .changelog-body :global(a:hover) {
    text-decoration: underline;
  }
  .changelog-body :global(img) {
    margin-bottom: 2.5rem;
    width: 100%;
    overflow: hidden;
    border-radius: 0.75rem;
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.15),
      0 0 0 1px var(--color-border);
  }
</style>
