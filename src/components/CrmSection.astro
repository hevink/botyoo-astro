---
// CRM section, positions Botyoo as a real CRM, not just a DM bot.
// Left: copy + benefit bullets. Right: an inbox screenshot (inbox.png)
// in a card styled to match the StatsGrid illustration cards.

const benefits = [
  "Every comment, reply, and DM saved as a contact, automatically",
  "Email, phone, follower count, source, and tags on every lead",
  "Filter and segment your audience, then export to CSV or your email tool",
  "Unlimited contact storage, you only meter what you message",
]
---

<section class="bg-background py-12 md:py-24">
  <div class="mx-auto w-full max-w-5xl px-6">
    <div class="grid items-center gap-12 md:grid-cols-2 md:gap-16">
      {/* Left, copy */}
      <div class="text-balance">
        <span class="text-primary font-mono text-sm uppercase">Built-in CRM</span>
        <h2
          class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl"
        >
          A real CRM for your Instagram audience
        </h2>
        <p class="text-muted-foreground mt-4 text-lg">
          Botyoo isn't just a DM bot. Every lead you capture lands in a CRM you
          own, organized, searchable, and yours to keep. Your audience finally
          lives somewhere outside the app.
        </p>

        <ul class="mt-6 space-y-3">
          {
            benefits.map((b) => (
              <li class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary mt-0.5 size-5 shrink-0"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <span class="text-foreground text-sm">{b}</span>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Right, inbox preview */}
      <div class="md:-mr-8 lg:-mr-16">
        <img
          src="/inbox.png"
          alt="Botyoo inbox with contacts and conversations"
          width="1024"
          height="600"
          class="h-auto w-full object-contain"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
