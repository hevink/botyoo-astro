---
// CRM section, positions Botyoo as a real CRM, not just a DM bot.
// Left: copy + benefit bullets. Right: a faux contacts-table preview card
// styled to match the StatsGrid illustration cards (bg-card, ring-foreground/10).

const benefits = [
  "Every comment, reply, and DM saved as a contact, automatically",
  "Email, phone, follower count, source, and tags on every lead",
  "Filter and segment your audience, then export to CSV or your email tool",
  "Unlimited contact storage, you only meter what you message",
]

const contacts = [
  { name: "amara.codes", followers: "12.4k", tag: "Hot lead", email: "✓" },
  { name: "studio.mae", followers: "3.1k", tag: "Webinar", email: "✓" },
  { name: "thefitkofi", followers: "48.9k", tag: "Customer", email: "✓" },
  { name: "leoribeiro", followers: "920", tag: "New", email: ", " },
]
---

<section class="bg-background py-12 md:py-24">
  <div class="mx-auto w-full max-w-5xl px-6">
    <div class="grid items-center gap-12 md:grid-cols-2 md:gap-16">
      {/* Left, copy */}
      <div class="text-balance">
        <span class="text-primary font-mono text-sm uppercase">Built-in CRM</span>
        <h2
          class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl"
        >
          A real CRM for your Instagram audience
        </h2>
        <p class="text-muted-foreground mt-4 text-lg">
          Botyoo isn't just a DM bot. Every lead you capture lands in a CRM you
          own, organized, searchable, and yours to keep. Your audience finally
          lives somewhere outside the app.
        </p>

        <ul class="mt-6 space-y-3">
          {
            benefits.map((b) => (
              <li class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary mt-0.5 size-5 shrink-0"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <span class="text-foreground text-sm">{b}</span>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Right, contacts table preview */}
      <div
        class="bg-card ring-foreground/10 overflow-hidden rounded-2xl border border-transparent shadow-xl shadow-black/10 ring-1"
      >
        <div class="border-foreground/10 flex items-center justify-between border-b px-5 py-3">
          <div class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground size-4"
            >
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            <span class="text-sm font-medium">Contacts</span>
          </div>
          <span class="text-muted-foreground font-mono text-xs">2,340 leads</span>
        </div>

        <div class="divide-foreground/5 divide-y">
          {
            contacts.map((c) => (
              <div class="grid grid-cols-[1fr_auto] items-center gap-3 px-5 py-3">
                <div class="flex items-center gap-3">
                  <div class="bg-muted ring-foreground/10 flex size-8 items-center justify-center rounded-full text-xs font-medium ring-1">
                    {c.name.charAt(0).toUpperCase()}
                  </div>
                  <div class="space-y-0.5">
                    <div class="text-sm font-medium">@{c.name}</div>
                    <div class="text-muted-foreground text-xs">
                      {c.followers} followers · email {c.email}
                    </div>
                  </div>
                </div>
                <span class="bg-primary/10 text-primary inline-flex h-6 items-center rounded-full px-2.5 text-xs font-medium">
                  {c.tag}
                </span>
              </div>
            ))
          }
        </div>

        <div class="border-foreground/10 flex items-center justify-between border-t px-5 py-3">
          <span class="text-muted-foreground text-xs">Filter · Segment · Export</span>
          <span class="text-primary text-xs font-medium">Export CSV →</span>
        </div>
      </div>
    </div>
  </div>
</section>
