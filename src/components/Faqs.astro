---
// FAQ section — Tailark dark-landing-one port with Botyoo content.
// Uses native <details>/<summary> so no extra JS runtime is needed.

const groups = [
  {
    heading: "General",
    items: [
      {
        q: "What does Botyoo do?",
        a: "Botyoo automates Instagram DMs. Trigger a personalized DM when someone comments a keyword, replies to a story, or follows you — no ads, no forms, just conversations that turn into sales.",
      },
      {
        q: "How is Botyoo different from ManyChat?",
        a: "Botyoo is built around Instagram-first workflows (comment-to-DM, follow-first, shared inbox) and charges by workspace, not per contact. You get the core automations without the per-lead pricing tax.",
      },
      {
        q: "Is there a free plan?",
        a: "Yes — you can start on the free plan, connect an Instagram account, and launch your first comment-to-DM automation without a credit card.",
      },
    ],
  },
  {
    heading: "Setup & safety",
    items: [
      {
        q: "Will automating DMs get my account banned?",
        a: "No. Botyoo uses the official Meta Graph API, which is the method Instagram itself approves for business messaging. Automation rules stay inside Meta's policies.",
      },
      {
        q: "How do I connect my Instagram account?",
        a: "Convert your profile to a Business or Creator account, connect it to a Facebook Page, and click Connect Instagram in Botyoo. The whole setup takes about two minutes.",
      },
      {
        q: "Can I cancel anytime?",
        a: "Yes. Plans are month-to-month. Cancel from your dashboard and you keep access until the end of the current billing period.",
      },
    ],
  },
]
---

<section class="bg-background py-16 md:py-24">
  <div class="mx-auto max-w-5xl px-1 md:px-6">
    <div class="mx-auto mb-12 max-w-2xl px-6 text-balance text-center md:mb-16">
      <span class="text-primary font-mono text-sm uppercase">FAQs</span>
      <h2
        class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl"
      >
        Your questions answered
      </h2>
      <p class="text-muted-foreground mx-auto mt-4 max-w-xl text-balance text-lg">
        Everything you need to know about running Instagram DM automation with
        Botyoo. Can't find what you're looking for? Contact our{" "}
        <a class="text-primary font-medium hover:underline" href="/contact">
          customer support team
        </a>.
      </p>
    </div>

    <div class="mx-auto max-w-3xl">
      <div class="space-y-12 md:px-4 md:pb-4 md:pt-4">
        {
          groups.map((group) => (
            <div class="space-y-4">
              <h3 class="text-foreground pl-6 text-lg font-semibold">
                {group.heading}
              </h3>
              <div class="-space-y-1">
                {group.items.map((item) => (
                  <details
                    class="group border-b last:border-b-0 rounded-xl border-none px-6 py-1 open:bg-card open:ring-1 open:ring-border open:shadow-sm open:shadow-black/5"
                  >
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-4 py-4 text-left text-base font-medium outline-none [&::-webkit-details-marker]:hidden">
                      <span>{item.q}</span>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="text-muted-foreground pointer-events-none size-4 shrink-0 translate-y-0.5 transition-transform duration-200 group-open:rotate-180"
                      >
                        <path d="m6 9 6 6 6-6" />
                      </svg>
                    </summary>
                    <p class="text-muted-foreground pb-4 text-sm">{item.a}</p>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
