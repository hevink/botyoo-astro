---
// Unified-platform section with feature accordion on left,
// dynamic illustration cards on right that change based on selected feature.

const features = [
  {
    title: "Reply to every comment",
    body: "Botyoo answers every qualifying comment with a personalized DM — no comment ignored, no lead lost, and the algorithm sees your engagement spike.",
    icon: "brain",
  },
  {
    title: "Gate links behind a follow",
    body: "Only send offers, discounts, and lead magnets to people who follow you. You grow your audience at the same time you deliver value.",
    icon: "globe",
  },
  {
    title: "Capture email and phone in-DM",
    body: "Collect contact details right inside the Instagram DM — no redirects, no drop-off — and push them to your CRM or email tool.",
    icon: "form",
  },
  {
    title: "One inbox for the whole team",
    body: "Route every DM to a shared inbox, assign owners, and keep replies consistent without stepping on each other's conversations.",
    icon: "bot",
  },
]

const BG_IMAGE =
  "https://images.unsplash.com/photo-1723869791623-3b6a012f996b?q=80&w=2340&auto=format&fit=crop"
---

<div
  data-theme="global"
  class="selection:bg-foreground/10 selection:text-foreground bg-background"
>
  <section class="bg-background overflow-hidden pt-24 pb-12">
    <div class="mx-auto mb-12 max-w-2xl px-6 text-balance text-center md:mb-16">
      <span class="text-primary font-mono text-sm uppercase">Features</span>
      <h2 class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        Everything you need to run Instagram DMs at scale
      </h2>
      <p class="text-muted-foreground mx-auto mt-4 max-w-xl text-balance text-lg">
        Comment-to-DM flows, follow-first gating, and a shared team inbox —
        without the per-contact pricing. Botyoo is Meta-partner ready so your
        automations keep firing.
      </p>
    </div>

    <div class="mx-auto my-1 max-w-5xl px-6">
      <div class="relative">
        {/* Corner crosses */}
        {
          [
            "-translate-[calc(50%-0.5px)]",
            "right-0 -translate-y-[calc(50%-0.5px)] translate-x-[calc(50%-0.5px)]",
            "bottom-0 right-0 translate-x-[calc(50%-0.5px)] translate-y-[calc(50%-0.5px)]",
            "bottom-0 -translate-x-[calc(50%-0.5px)] translate-y-[calc(50%-0.5px)]",
          ].map((pos) => (
            <div
              aria-hidden="true"
              class={`mask-radial-from-15% z-1 before:bg-foreground/25 after:bg-foreground/25 absolute size-3 before:absolute before:inset-0 before:m-auto before:h-px after:absolute after:inset-0 after:m-auto after:w-px ${pos}`}
            />
          ))
        }

        <div class="border-foreground/10 relative grid overflow-hidden border md:grid-cols-2 grid-cols-1">
          {/* Left column */}
          <div class="flex flex-col gap-12 p-8 border-b border-foreground/10 md:border-b-0 md:border-r md:border-foreground/10">
            <div class="text-balance">
              <h3 class="text-foreground text-2xl font-semibold">
                The Instagram DM stack ManyChat users wish they switched to
              </h3>
              <p class="text-muted-foreground mb-6 mt-4">
                Comment-to-DM flows, follow-first gating, and a live shared
                inbox — without the per-contact pricing. Botyoo is Meta-partner
                ready so your automations keep firing.
              </p>
              <a
                href="/pricing"
                class="cursor-pointer inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-all focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring shadow-sm shadow-black/10 border border-transparent bg-card ring-1 ring-foreground/10 duration-200 hover:bg-muted/50 dark:ring-foreground/15 dark:hover:bg-muted/50 h-8 rounded-md px-3 text-xs"
              >
                See pricing
              </a>
            </div>

            {/* Accordion */}
            <div
              class="mt-auto grid divide-y transition-all duration-300 grid-rows-[1fr_auto_auto_auto]"
              data-accordion
            >
              {
                features.map((f, i) => (
                  <div
                    data-accordion-item
                    data-index={i}
                    data-expanded={i === 0 ? "true" : "false"}
                    class="not-first:border-t not-first:border-t-card group relative grid grid-rows-[auto_1fr]"
                  >
                    <button
                      type="button"
                      data-accordion-trigger
                      class="group flex w-full cursor-pointer items-center gap-3 py-4 text-left"
                    >
                      {f.icon === "brain" && (
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-accordion-icon class="size-4 shrink-0 transition-colors text-muted-foreground group-hover:text-foreground">
                          <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z" />
                          <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z" />
                        </svg>
                      )}
                      {f.icon === "globe" && (
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-accordion-icon class="size-4 shrink-0 transition-colors text-muted-foreground group-hover:text-foreground">
                          <circle cx="12" cy="12" r="10" />
                          <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
                          <path d="M2 12h20" />
                        </svg>
                      )}
                      {f.icon === "bot" && (
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-accordion-icon class="size-4 shrink-0 transition-colors text-muted-foreground group-hover:text-foreground">
                          <path d="M12 8V4H8" />
                          <rect width="16" height="12" x="4" y="8" rx="2" />
                          <path d="M2 14h2" /><path d="M20 14h2" />
                          <path d="M15 13v2" /><path d="M9 13v2" />
                        </svg>
                      )}
                      {f.icon === "form" && (
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-accordion-icon class="size-4 shrink-0 transition-colors text-muted-foreground group-hover:text-foreground">
                          <rect width="18" height="18" x="3" y="3" rx="2" />
                          <path d="M8 10h8" /><path d="M8 14h5" /><path d="M12 17.5h4" />
                        </svg>
                      )}
                      <h3 data-accordion-title class="group-hover:text-foreground font-medium transition-colors text-muted-foreground">
                        {f.title}
                      </h3>
                    </button>
                    <div data-accordion-body class="grid transition-[grid-template-rows] duration-300 grid-rows-[0fr]">
                      <div class="overflow-hidden">
                        <p class="text-muted-foreground pl-6.5 text-balance pb-6">{f.body}</p>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          {/* Right column — dynamic content cards */}
          <div class="relative overflow-hidden min-h-[400px] md:min-h-[500px]">
            <div class="absolute inset-0">
              {/* Feature cards — one per accordion item, toggled via JS */}
              <div class="relative z-10 h-full">
                {/* Card 0: Reply to every comment */}
                <div data-feature-card="0" class="absolute inset-0 flex items-center justify-center transition-opacity duration-300 opacity-100">
                  <div class="scale-85 overflow-hidden max-w-md px-6">
                    <div class="bg-card/95 shadow-black/4 ring-border rounded-2xl p-6 shadow-md ring-1 relative">
                      <div class="mask-t-from-5% bg-card/50 mask-t-to-65% absolute inset-0 rounded-2xl backdrop-blur"></div>
                      <div class="relative space-y-4">
                        <div class="flex items-center gap-2">
                          <div class="size-2 rounded-full bg-green-400 animate-pulse"></div>
                          <span class="text-xs text-muted-foreground">Live — 3 posts monitored</span>
                        </div>
                        <div class="text-lg font-semibold">Comment → DM Engine</div>
                        <div class="space-y-3 text-sm">
                          <div class="flex items-center gap-3 rounded-lg bg-foreground/5 p-3">
                            <div class="size-8 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center text-white text-xs font-bold">JK</div>
                            <div class="flex-1 min-w-0">
                              <p class="text-foreground font-medium text-xs">@jake_fitness</p>
                              <p class="text-muted-foreground text-xs truncate">"Where can I get this? 🔥"</p>
                            </div>
                            <span class="text-xs text-green-400 font-medium">DM sent ✓</span>
                          </div>
                          <div class="flex items-center gap-3 rounded-lg bg-foreground/5 p-3">
                            <div class="size-8 rounded-full bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-white text-xs font-bold">SM</div>
                            <div class="flex-1 min-w-0">
                              <p class="text-foreground font-medium text-xs">@sarah_m</p>
                              <p class="text-muted-foreground text-xs truncate">"Need this! Link please"</p>
                            </div>
                            <span class="text-xs text-green-400 font-medium">DM sent ✓</span>
                          </div>
                          <div class="flex items-center gap-3 rounded-lg bg-foreground/5 p-3">
                            <div class="size-8 rounded-full bg-gradient-to-br from-orange-400 to-red-500 flex items-center justify-center text-white text-xs font-bold">AR</div>
                            <div class="flex-1 min-w-0">
                              <p class="text-foreground font-medium text-xs">@alex.runs</p>
                              <p class="text-muted-foreground text-xs truncate">"How much is this?"</p>
                            </div>
                            <span class="text-xs text-yellow-400 font-medium">Sending...</span>
                          </div>
                        </div>
                        <div class="pt-2 border-t border-foreground/10 flex justify-between text-xs text-muted-foreground">
                          <span>247 DMs sent today</span>
                          <span class="text-green-400">98% delivery rate</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Card 1: Gate links behind a follow */}
                <div data-feature-card="1" class="absolute inset-0 flex items-center justify-center transition-opacity duration-300 opacity-0">
                  <div class="scale-85 overflow-hidden max-w-md px-6">
                    <div class="bg-card/95 shadow-black/4 ring-border rounded-2xl p-6 shadow-md ring-1 relative">
                      <div class="mask-t-from-5% bg-card/50 mask-t-to-65% absolute inset-0 rounded-2xl backdrop-blur"></div>
                      <div class="relative space-y-4">
                        <div class="text-lg font-semibold">Follow-First Gate</div>
                        <p class="text-muted-foreground text-sm">User must follow before receiving the link</p>
                        <div class="space-y-3">
                          <div class="rounded-lg border border-foreground/10 p-4 space-y-3">
                            <div class="flex items-center justify-between">
                              <span class="text-sm font-medium">@new_visitor</span>
                              <span class="text-xs bg-yellow-500/20 text-yellow-400 px-2 py-0.5 rounded-full">Not following</span>
                            </div>
                            <div class="bg-foreground/5 rounded-lg p-3 text-sm text-muted-foreground">
                              "Hey! 👋 Follow us first to unlock the exclusive discount link. Tap the Follow button above and I'll send it right over!"
                            </div>
                          </div>
                          <div class="rounded-lg border border-green-500/30 bg-green-500/5 p-4 space-y-3">
                            <div class="flex items-center justify-between">
                              <span class="text-sm font-medium">@new_visitor</span>
                              <span class="text-xs bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full">Now following ✓</span>
                            </div>
                            <div class="bg-foreground/5 rounded-lg p-3 text-sm text-muted-foreground">
                              "Awesome, you're in! 🎉 Here's your exclusive 30% off link: botyoo.com/deal"
                            </div>
                          </div>
                        </div>
                        <div class="pt-2 border-t border-foreground/10 flex justify-between text-xs text-muted-foreground">
                          <span>+1,420 new followers this week</span>
                          <span class="text-green-400">37% conversion</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Card 2: Capture email and phone */}
                <div data-feature-card="2" class="absolute inset-0 flex items-center justify-center transition-opacity duration-300 opacity-0">
                  <div class="scale-85 overflow-hidden max-w-md px-6">
                    <div class="bg-card/95 shadow-black/4 ring-border rounded-2xl p-6 shadow-md ring-1 relative">
                      <div class="mask-t-from-5% bg-card/50 mask-t-to-65% absolute inset-0 rounded-2xl backdrop-blur"></div>
                      <div class="relative space-y-4">
                        <div class="text-lg font-semibold">In-DM Lead Capture</div>
                        <p class="text-muted-foreground text-sm">Collect emails & phone numbers without leaving Instagram</p>
                        <div class="space-y-2 text-sm">
                          <div class="flex gap-2">
                            <div class="size-6 rounded-full bg-primary/20 flex items-center justify-center shrink-0 mt-0.5">
                              <span class="text-primary text-xs">B</span>
                            </div>
                            <div class="bg-foreground/5 rounded-lg rounded-tl-none p-3 text-muted-foreground">
                              "Thanks for your interest! 🙌 What's the best email to send the free guide to?"
                            </div>
                          </div>
                          <div class="flex gap-2 justify-end">
                            <div class="bg-primary/10 rounded-lg rounded-tr-none p-3 text-foreground">
                              "sarah@gmail.com"
                            </div>
                            <div class="size-6 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center shrink-0 mt-0.5">
                              <span class="text-white text-xs">S</span>
                            </div>
                          </div>
                          <div class="flex gap-2">
                            <div class="size-6 rounded-full bg-primary/20 flex items-center justify-center shrink-0 mt-0.5">
                              <span class="text-primary text-xs">B</span>
                            </div>
                            <div class="bg-foreground/5 rounded-lg rounded-tl-none p-3 text-muted-foreground">
                              "Got it! ✅ Check your inbox — the guide is on its way. Want me to text you a reminder too? Drop your number!"
                            </div>
                          </div>
                        </div>
                        <div class="pt-2 border-t border-foreground/10 flex justify-between text-xs text-muted-foreground">
                          <span>892 emails collected</span>
                          <span class="text-green-400">64% capture rate</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Card 3: One inbox for the whole team */}
                <div data-feature-card="3" class="absolute inset-0 flex items-center justify-center transition-opacity duration-300 opacity-0">
                  <div class="scale-85 overflow-hidden max-w-md px-6">
                    <div class="bg-card/95 shadow-black/4 ring-border rounded-2xl p-6 shadow-md ring-1 relative">
                      <div class="mask-t-from-5% bg-card/50 mask-t-to-65% absolute inset-0 rounded-2xl backdrop-blur"></div>
                      <div class="relative space-y-4">
                        <div class="text-lg font-semibold">Shared Team Inbox</div>
                        <p class="text-muted-foreground text-sm">Everyone sees the same conversations — no overlap</p>
                        <div class="space-y-2">
                          <div class="flex items-center gap-3 rounded-lg bg-foreground/5 p-3">
                            <div class="size-8 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-xs font-bold">MK</div>
                            <div class="flex-1 min-w-0">
                              <div class="flex items-center justify-between">
                                <p class="text-foreground font-medium text-xs">@mike_k</p>
                                <span class="text-xs bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded-full">Assigned: You</span>
                              </div>
                              <p class="text-muted-foreground text-xs truncate">"Can I get a bulk discount?"</p>
                            </div>
                          </div>
                          <div class="flex items-center gap-3 rounded-lg bg-foreground/5 p-3">
                            <div class="size-8 rounded-full bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center text-white text-xs font-bold">LP</div>
                            <div class="flex-1 min-w-0">
                              <div class="flex items-center justify-between">
                                <p class="text-foreground font-medium text-xs">@lisa_p</p>
                                <span class="text-xs bg-purple-500/20 text-purple-400 px-2 py-0.5 rounded-full">Assigned: Sarah</span>
                              </div>
                              <p class="text-muted-foreground text-xs truncate">"When does the sale end?"</p>
                            </div>
                          </div>
                          <div class="flex items-center gap-3 rounded-lg bg-foreground/5 p-3 border border-green-500/20">
                            <div class="size-8 rounded-full bg-gradient-to-br from-orange-400 to-red-500 flex items-center justify-center text-white text-xs font-bold">TN</div>
                            <div class="flex-1 min-w-0">
                              <div class="flex items-center justify-between">
                                <p class="text-foreground font-medium text-xs">@tom_n</p>
                                <span class="text-xs bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full">Resolved ✓</span>
                              </div>
                              <p class="text-muted-foreground text-xs truncate">"Thanks, got it!"</p>
                            </div>
                          </div>
                        </div>
                        <div class="pt-2 border-t border-foreground/10 flex justify-between text-xs text-muted-foreground">
                          <span>3 team members online</span>
                          <span class="text-green-400">Avg reply: 2 min</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {/* Dithered background image */}
              <div class="dither absolute inset-0 opacity-75 dark:opacity-25">
                <img alt="" aria-hidden="true" loading="lazy" decoding="async" class="size-full object-cover opacity-50" src={BG_IMAGE} />
              </div>
              <img alt="" aria-hidden="true" loading="lazy" decoding="async" class="size-full object-cover opacity-75 dark:opacity-40 absolute inset-0" src={BG_IMAGE} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  // Accordion + feature card switcher
  document.querySelectorAll<HTMLElement>("[data-accordion]").forEach((root) => {
    const items = Array.from(root.querySelectorAll<HTMLElement>("[data-accordion-item]"))
    const cards = document.querySelectorAll<HTMLElement>("[data-feature-card]")

    const setExpanded = (index: number) => {
      items.forEach((item, i) => {
        const expanded = i === index
        item.dataset.expanded = expanded ? "true" : "false"
        const body = item.querySelector<HTMLElement>("[data-accordion-body]")
        body?.classList.toggle("grid-rows-[1fr]", expanded)
        body?.classList.toggle("grid-rows-[0fr]", !expanded)
        const title = item.querySelector<HTMLElement>("[data-accordion-title]")
        const icon = item.querySelector<HTMLElement>("[data-accordion-icon]")
        title?.classList.toggle("text-foreground", expanded)
        title?.classList.toggle("text-muted-foreground", !expanded)
        icon?.classList.toggle("text-foreground", expanded)
        icon?.classList.toggle("text-muted-foreground", !expanded)
      })

      // Switch right-side cards
      cards.forEach((card) => {
        const cardIndex = card.dataset.featureCard
        card.classList.toggle("opacity-100", cardIndex === String(index))
        card.classList.toggle("opacity-0", cardIndex !== String(index))
      })
    }

    items.forEach((item, i) => {
      item.querySelector<HTMLButtonElement>("[data-accordion-trigger]")
        ?.addEventListener("click", () => setExpanded(i))
    })

    // Open first on load
    setExpanded(0)
  })
</script>
