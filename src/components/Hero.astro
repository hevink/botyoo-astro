---
const CONSTELLATION_SRC = "/constellation.webp"
---

<section class="bg-background relative overflow-hidden">
  {/* Background layer 1: dithered */}
  <div
    class="mask-b-from-55% mask-b-to-75% mask-radial-from-45% dither mask-radial-at-bottom mask-radial-[125%_80%] lg:aspect-3/2 absolute inset-0 opacity-15"
  >
    <img
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      decoding="async"
      width="2342"
      height="1561"
      class="size-full object-cover"
      src={CONSTELLATION_SRC}
    />
  </div>

  {/* Background layer 2 */}
  <div
    class="mask-b-from-55% mask-b-to-75% mask-radial-from-45% mask-radial-at-bottom mask-radial-[125%_80%] lg:aspect-7/5 absolute inset-0"
  >
    <img
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      decoding="async"
      width="2342"
      height="1561"
      class="size-full object-cover"
      src={CONSTELLATION_SRC}
    />
  </div>

  <div class="relative z-10 pb-20 pt-24 md:pt-32 lg:pt-48">
    <div
      class="relative z-10 mx-auto flex max-w-5xl flex-col items-center gap-4 px-6 text-center"
    >
      <div class="flex flex-col items-center">
        <img
          src="/meta-tech-provider.png"
          alt="Meta Tech Provider verified"
          width="180"
          height="60"
          class="mb-6 h-12 w-auto md:h-14"
        />
        <h1
          class="text-foreground text-balance text-5xl font-semibold lg:text-6xl"
        >
          Turn every <span class="max-md:hidden">follower</span> into {" "}
          <span
            class="bg-linear-to-b from-foreground/50 to-foreground/95 bg-clip-text text-transparent [-webkit-text-stroke:0.5px_var(--color-foreground)]"
          >
            a qualified lead
          </span>
        </h1>
      </div>
      <div class="flex max-w-lg flex-col items-center">
        <p
          class="text-muted-foreground mb-6 text-balance text-lg lg:text-xl"
        >
          Botyoo replies to every comment, captures leads right inside the DM,
          stores them in a real CRM, and runs campaigns that sell. It's not a
          chatbot, it's your entire Instagram funnel in one tool.
        </p>
        <div class="flex items-center gap-3">
          <a
            href="https://app.botyoo.com/dashboard"
            class="btn btn-primary btn-lg"
          >
            Get Started
          </a>
          <button
            id="watch-demo-btn"
            class="cursor-pointer inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring shadow-sm shadow-black/15 border border-transparent ring-1 duration-200 dark:ring-foreground/15 dark:hover:bg-muted/50 h-10 rounded-md px-4 text-sm bg-foreground/10 ring-foreground/20 hover:bg-foreground/15 backdrop-blur"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
              <path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd" />
            </svg>
            Watch Demo
          </button>
        </div>
      </div>
    </div>

    {/* Product frame */}
    <div
      class="@container perspective-dramatic mask-[radial-gradient(ellipse_80%_95%_at_50%_0%,#000_80%,transparent_100%)] max-lg:pt-12 pointer-events-none"
    >
      <div
        class="rotate-x-[0.125deg] before:z-1 before:bg-linear-to-b relative mx-auto max-w-6xl px-3 before:absolute before:inset-0 before:inset-x-4 before:top-0 before:rounded-2xl before:from-blue-950 before:opacity-20 before:mix-blend-color lg:px-12 lg:pt-20 lg:before:inset-x-12 lg:before:top-20 pointer-events-none"
      >
        <div
          class="bg-linear-to-b from-foreground rotate-66 absolute inset-0 z-10 mx-auto w-8 -translate-y-44 rounded-full opacity-5 blur-xl pointer-events-none"
        >
        </div>
        <div
          class="bg-linear-to-b from-foreground rotate-66 absolute inset-0 z-10 mx-auto w-16 -translate-y-32 translate-x-44 rounded-full opacity-20 blur-2xl pointer-events-none"
        >
        </div>
        <div
          class="bg-foreground/5 border-foreground/5 rounded-[15px] border p-0.5 relative z-20 pointer-events-auto"
        >
          <div
            class="bg-background sm:aspect-3/2 ring-foreground/10 relative aspect-square origin-top overflow-hidden rounded-xl p-1 shadow ring-1"
          >
            <button
              id="hero-video-btn"
              aria-label="Watch Botyoo demo video"
              class="group relative block size-full cursor-pointer z-10 pointer-events-auto"
            >
              <img
                alt="Botyoo product illustration"
                fetchpriority="high"
                decoding="async"
                width="1123"
                height="748"
                class="size-full object-contain object-left-top transition-opacity duration-300 group-hover:opacity-80"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 1123px"
                src="/hero.png"
              />
              {/* Play button overlay */}
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="flex size-16 items-center justify-center rounded-full bg-white/90 shadow-xl backdrop-blur-sm transition-transform duration-300 group-hover:scale-110 md:size-20">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7 translate-x-0.5 text-gray-900 md:size-9">
                    <path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd" />
                  </svg>
                </div>
              </div>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{/* YouTube Video Modal */}
<div
  id="video-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm p-4 md:p-6"
  role="dialog"
  aria-modal="true"
  aria-label="Botyoo demo video"
>
  {/* Info-card style container */}
  <div
    id="video-card"
    class="bg-card border border-border w-full max-w-5xl rounded-2xl shadow-2xl overflow-hidden"
  >
    {/* Card header */}
    <div class="flex items-center justify-between gap-4 px-5 py-3 border-b border-border">
      <p class="font-medium text-sm text-foreground">Botyoo: Full Product Walkthrough</p>
      <button
        id="close-modal-btn"
        aria-label="Close video"
        class="flex size-8 shrink-0 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
          <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 0 1 1.06 0L12 10.94l5.47-5.47a.75.75 0 1 1 1.06 1.06L13.06 12l5.47 5.47a.75.75 0 1 1-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 0 1-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>
    {/* Card content: video */}
    <div class="m-1 rounded-lg overflow-hidden bg-black">
      <div class="relative aspect-video w-full">
        <iframe
          id="video-iframe"
          class="absolute inset-0 size-full"
          src=""
          title="Botyoo Demo Video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</div>

<script>
  // Use DOMContentLoaded to guarantee elements exist
  document.addEventListener("DOMContentLoaded", () => {
    const YOUTUBE_URL = "https://www.youtube.com/embed/VYKKTqZ0J9s?autoplay=1&rel=0";

    const modal = document.getElementById("video-modal") as HTMLElement;
    const card = document.getElementById("video-card") as HTMLElement;
    const iframe = document.getElementById("video-iframe") as HTMLIFrameElement;
    const heroBt = document.getElementById("hero-video-btn");
    const watchDemoBtn = document.getElementById("watch-demo-btn");
    const closeBtn = document.getElementById("close-modal-btn");

    function openModal() {
      iframe.src = YOUTUBE_URL;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      iframe.src = "";
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    }

    heroBt?.addEventListener("click", openModal);
    watchDemoBtn?.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);

    // Close on backdrop click (not on the card itself)
    modal?.addEventListener("click", (e) => {
      if (!card.contains(e.target as Node)) closeModal();
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        closeModal();
      }
    });
  });
</script>
