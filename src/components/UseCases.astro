---
// Use-cases grid: bordered icon list (Tailark "features" style).
// Each item shows a lucide icon, a title (dt) and a description (dd).
interface Item {
  title: string
  desc: string
}

interface Props {
  items: Item[]
}

const { items } = Astro.props

// A small set of lucide icons cycled across items for visual variety.
const icons = [
  // zap
  `<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>`,
  // message-circle
  `<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>`,
  // users
  `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  // link
  `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`,
  // bar-chart-3
  `<path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/>`,
  // sparkles
  `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>`,
]
---

<div class="@container">
  <dl
    class="grid @md:grid-cols-2 @max-md:gap-10 @md:gap-y-12 *:border-l *:border-border *:px-6"
  >
    {
      items.map((item, i) => (
        <div>
          <dt class="text-foreground flex flex-col gap-8 font-medium">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary size-5"
              set:html={icons[i % icons.length]}
            />
            {item.title}
          </dt>
          <dd class="text-muted-foreground mt-3 text-sm leading-relaxed">
            {item.desc}
          </dd>
        </div>
      ))
    }
  </dl>
</div>
