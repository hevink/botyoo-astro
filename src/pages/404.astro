---
import Layout from "../layouts/Layout.astro"
---

<Layout
  title="404 — Page Not Found · Botyoo"
  description="The page you're looking for doesn't exist. Head back to Botyoo's homepage."
>
  <main class="bg-background flex min-h-screen flex-col items-center justify-center px-6 text-center">

    {/* Decorative glow */}
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 overflow-hidden"
    >
      <div class="absolute left-1/2 top-1/3 h-[400px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-indigo-500/10 blur-[120px]"></div>
    </div>

    <div class="relative z-10 flex max-w-lg flex-col items-center gap-6 animate-[slide-up-fade_600ms_backwards]">

      {/* Big 404 */}
      <p class="bg-gradient-to-b from-indigo-400 to-indigo-600 bg-clip-text text-8xl font-black tracking-tighter text-transparent sm:text-9xl select-none">
        404
      </p>

      <div class="space-y-3">
        <h1 class="text-foreground text-2xl font-bold tracking-tight sm:text-3xl">
          Page not found
        </h1>
        <p class="text-muted-foreground text-base leading-relaxed">
          Looks like this page went offline. Maybe it was automated away — or never existed in the first place.
        </p>
      </div>

      {/* Actions */}
      <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
        <a
          href="/"
          class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground shadow-md transition-all hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          Back to home
        </a>
        <a
          href="/contact"
          class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl border border-border bg-transparent px-5 py-2.5 text-sm font-medium text-foreground transition-all hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          Contact support
        </a>
      </div>

      {/* Quick links */}
      <div class="mt-4 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
        {[
          { label: "Pricing", href: "/pricing" },
          { label: "Blog", href: "/blog" },
          { label: "Changelog", href: "/changelog" },
          { label: "About", href: "/about" },
        ].map((link) => (
          <a href={link.href} class="text-muted-foreground hover:text-primary transition-colors">
            {link.label}
          </a>
        ))}
      </div>

    </div>
  </main>
</Layout>

<style>
  @keyframes slide-up-fade {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
