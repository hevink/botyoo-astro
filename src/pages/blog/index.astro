---
import { getCollection } from "astro:content"
import Layout from "../../layouts/Layout.astro"

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

// Derive unique tags for category tabs
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))]

// Split posts - all in one list
const allPosts = posts
---

<Layout title="Blog - Botyoo" description="News, insights and more from Botyoo.">
  <section class="bg-background py-16 md:py-24">
    <div class="mx-auto max-w-5xl px-6">
      <div class="max-w-md">
        <span class="text-muted-foreground">Blog</span>
        <h1 class="text-muted-foreground mt-4 text-balance text-4xl font-semibold">
          News, insights and more from <strong class="text-foreground font-semibold">Botyoo</strong>
        </h1>
      </div>
    </div>

    <!-- Category Tabs -->
    <div class="bg-background sticky top-0 z-10 my-12">
      <div class="mx-auto max-w-5xl px-6">
        <div class="flex justify-between gap-4 border-b max-md:-mx-6">
          <div class="-ml-0.5 flex snap-x snap-mandatory overflow-x-auto py-3 max-md:px-6" role="tablist" aria-label="Blog categories">
            <button role="tab" aria-selected="true" data-category="all" class="category-tab text-muted-foreground group snap-center px-1">
              <span class="flex w-fit items-center gap-2 rounded-md px-3 py-1.5 text-sm transition-colors bg-card ring-border text-primary shadow-sm ring-1 font-medium">
                <span class="capitalize">all</span>
              </span>
            </button>
            {allTags.map((tag) => (
              <button role="tab" aria-selected="false" data-category={tag} class="category-tab text-muted-foreground group snap-center px-1">
                <span class="flex w-fit items-center gap-2 rounded-md px-3 py-1.5 text-sm transition-colors hover:text-foreground group-hover:bg-foreground/5">
                  <span class="capitalize">{tag}</span>
                </span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-5xl px-6">
      <!-- All Blog Posts Grid -->
      <div class="relative">
        <div aria-hidden="true" class="pointer-events-none absolute -inset-x-px -inset-y-6 border-x"></div>
        <div aria-hidden="true" class="pointer-events-none absolute -inset-y-6 inset-x-0 left-1/2 w-6 -translate-x-3 border-x max-sm:hidden lg:left-1/3 lg:-translate-x-4"></div>
        <div aria-hidden="true" class="pointer-events-none absolute -inset-y-6 inset-x-0 right-1/3 ml-auto w-6 translate-x-4 border-x max-lg:hidden"></div>
        <div aria-hidden="true" class="pointer-events-none absolute -inset-x-6 -inset-y-px border-y"></div>
        <div class="grid gap-x-6 sm:grid-cols-2 lg:grid-cols-3">
          {allPosts.map((post, i) => (
            <article data-tags={post.data.tags.join(",")} class:list={["blog-card hover:bg-foreground/5 group relative row-span-4 grid grid-rows-subgrid gap-3 p-6 duration-200", i < allPosts.length - 3 ? "border-b" : ""]}>
              <time class="text-muted-foreground text-sm" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              </time>
              <h2 class="text-foreground text-lg font-semibold">
                <a class="before:absolute before:inset-0" href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>
              <p class="text-muted-foreground line-clamp-2">{post.data.description}</p>
              <div class="grid grid-cols-[1fr_auto] items-end gap-2 pt-4">
                <div class="grid grid-cols-[auto_1fr] items-center gap-2">
                  <div class="bg-card aspect-square size-6 overflow-hidden rounded-md border border-transparent shadow-md ring-1 ring-border">
                    {post.data.author.startsWith("Hevin") ? (
                      <img src="/hevin.png" alt={post.data.author} width="24" height="24" loading="lazy" decoding="async" class="size-full object-cover" />
                    ) : (
                      <div class="flex size-full items-center justify-center bg-primary/10 text-[10px] font-bold text-primary">
                        {post.data.author.charAt(0)}
                      </div>
                    )}
                  </div>
                  <span class="text-muted-foreground line-clamp-1 text-sm">{post.data.author}</span>
                </div>
                <div class="flex h-6 items-center">
                  <span class="text-primary group-hover:text-foreground flex items-center gap-1 text-sm font-medium transition-colors duration-200">
                    Read
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 translate-y-px duration-200 group-hover:translate-x-0.5" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
                  </span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll(".category-tab").forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = (btn as HTMLElement).dataset.category!
        document.querySelectorAll(".category-tab").forEach((t) => {
          t.setAttribute("aria-selected", "false")
          t.querySelector("span")!.className = "flex w-fit items-center gap-2 rounded-md px-3 py-1.5 text-sm transition-colors hover:text-foreground group-hover:bg-foreground/5"
        })
        btn.setAttribute("aria-selected", "true")
        btn.querySelector("span")!.className = "flex w-fit items-center gap-2 rounded-md px-3 py-1.5 text-sm transition-colors bg-card ring-border text-primary shadow-sm ring-1 font-medium"

        document.querySelectorAll(".blog-card").forEach((card) => {
          const tags = (card as HTMLElement).dataset.tags || ""
          if (category === "all" || tags.split(",").includes(category)) {
            ;(card as HTMLElement).style.display = ""
          } else {
            ;(card as HTMLElement).style.display = "none"
          }
        })
      })
    })
  </script>
</Layout>
