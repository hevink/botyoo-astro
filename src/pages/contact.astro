---
import Layout from "../layouts/Layout.astro"
---

<Layout
  title="Contact — Botyoo"
  description="Get in touch with the Botyoo team. We'd love to hear from you — whether it's a question, feedback, or a partnership idea."
>
  <main class="bg-background pb-24 pt-36">
    <div class="mx-auto flex max-w-2xl flex-col px-6">

      {/* Header */}
      <section class="animate-[slide-up-fade_600ms_backwards]">
        <span class="z-10 block w-fit rounded-lg border border-indigo-200/20 bg-indigo-50/10 px-3 py-1.5 text-sm font-semibold uppercase leading-4 tracking-tighter">
          <span class="bg-gradient-to-b from-indigo-400 to-indigo-500 bg-clip-text text-transparent">
            contact us
          </span>
        </span>
        <h1 class="text-foreground mt-4 text-balance py-2 text-4xl font-bold tracking-tighter sm:text-5xl">
          Let's talk
        </h1>
        <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
          Have a question, spotted a bug, or want to explore a partnership? Reach out — we reply fast.
        </p>
      </section>

      {/* Contact cards */}
      <section class="mt-12 grid gap-4 sm:grid-cols-2">
        {/* Email */}
        <a
          href="mailto:hevin@botyoo.com"
          class="group bg-card ring-foreground/5 flex flex-col gap-4 rounded-2xl border border-transparent p-6 shadow ring-1 transition-all duration-200 hover:border-indigo-500/30 hover:shadow-indigo-500/10"
        >
          <div class="flex size-10 items-center justify-center rounded-xl bg-indigo-50/10 text-indigo-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </div>
          <div>
            <p class="text-foreground font-semibold">Email</p>
            <p class="text-muted-foreground mt-1 text-sm">hevin@botyoo.com</p>
          </div>
          <span class="text-muted-foreground group-hover:text-primary mt-auto inline-flex items-center gap-1 text-sm transition-colors">
            Send an email
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </span>
        </a>

        {/* X / Twitter */}
        <a
          href="https://x.com/Hevin_69"
          target="_blank"
          rel="noopener noreferrer"
          class="group bg-card ring-foreground/5 flex flex-col gap-4 rounded-2xl border border-transparent p-6 shadow ring-1 transition-all duration-200 hover:border-indigo-500/30 hover:shadow-indigo-500/10"
        >
          <div class="flex size-10 items-center justify-center rounded-xl bg-indigo-50/10 text-indigo-400">
            <svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path fill="currentColor" d="M10.488 14.651L15.25 21h7l-7.858-10.478L20.93 3h-2.65l-5.117 5.886L8.75 3h-7l7.51 10.015L2.32 21h2.65zM16.25 19L5.75 5h2l10.5 14z"></path>
            </svg>
          </div>
          <div>
            <p class="text-foreground font-semibold">X (Twitter)</p>
            <p class="text-muted-foreground mt-1 text-sm">@Hevin_69</p>
          </div>
          <span class="text-muted-foreground group-hover:text-primary mt-auto inline-flex items-center gap-1 text-sm transition-colors">
            Message on X
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </span>
        </a>
      </section>

      {/* Contact form */}
      <section class="mt-12">
        <div class="bg-card ring-foreground/5 rounded-2xl border border-transparent p-8 shadow ring-1">
          <h2 class="text-foreground mb-6 text-xl font-semibold">Send a message</h2>

          <form
            id="contact-form"
            class="space-y-5"
            novalidate
          >
            <div class="grid gap-5 sm:grid-cols-2">
              <div class="space-y-1.5">
                <label for="name" class="text-foreground block text-sm font-medium">Name</label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  placeholder="Your name"
                  class="bg-background text-foreground placeholder:text-muted-foreground border-input focus:ring-primary w-full rounded-xl border px-4 py-2.5 text-sm outline-none transition focus:ring-2"
                />
              </div>
              <div class="space-y-1.5">
                <label for="email" class="text-foreground block text-sm font-medium">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  placeholder="you@example.com"
                  class="bg-background text-foreground placeholder:text-muted-foreground border-input focus:ring-primary w-full rounded-xl border px-4 py-2.5 text-sm outline-none transition focus:ring-2"
                />
              </div>
            </div>

            <div class="space-y-1.5">
              <label for="subject" class="text-foreground block text-sm font-medium">Subject</label>
              <input
                id="subject"
                name="subject"
                type="text"
                required
                placeholder="What's this about?"
                class="bg-background text-foreground placeholder:text-muted-foreground border-input focus:ring-primary w-full rounded-xl border px-4 py-2.5 text-sm outline-none transition focus:ring-2"
              />
            </div>

            <div class="space-y-1.5">
              <label for="message" class="text-foreground block text-sm font-medium">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell us what's on your mind..."
                class="bg-background text-foreground placeholder:text-muted-foreground border-input focus:ring-primary w-full resize-none rounded-xl border px-4 py-2.5 text-sm outline-none transition focus:ring-2"
              ></textarea>
            </div>

            {/* Status messages */}
            <p id="form-success" class="hidden rounded-xl bg-emerald-500/10 px-4 py-3 text-sm text-emerald-400">
              ✓ Message sent! We'll get back to you shortly.
            </p>
            <p id="form-error" class="hidden rounded-xl bg-red-500/10 px-4 py-3 text-sm text-red-400">
              Something went wrong. Please email us directly at hevin@botyoo.com.
            </p>

            <button
              type="submit"
              id="submit-btn"
              class="inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded-xl bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground shadow-md transition-all hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary disabled:opacity-60"
            >
              Send message
            </button>
          </form>
        </div>
      </section>

      {/* Response time note */}
      <p class="text-muted-foreground mt-8 text-center text-sm">
        We typically reply within a few hours. For urgent issues, DM on X for the fastest response.
      </p>

    </div>
  </main>
</Layout>

<style>
  @keyframes slide-up-fade {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null
  const btn = document.getElementById("submit-btn") as HTMLButtonElement | null
  const successMsg = document.getElementById("form-success")
  const errorMsg = document.getElementById("form-error")

  const API_URL = "https://api.botyoo.com/api/contact"

  form?.addEventListener("submit", async (e) => {
    e.preventDefault()
    if (!btn) return

    const data = new FormData(form)
    const name = (data.get("name") as string).trim()
    const email = (data.get("email") as string).trim()
    const subject = (data.get("subject") as string).trim()
    const message = (data.get("message") as string).trim()

    if (!name || !email || !subject || !message) return

    btn.disabled = true
    btn.textContent = "Sending…"
    successMsg?.classList.add("hidden")
    errorMsg?.classList.add("hidden")

    try {
      const res = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, email, subject, message }),
      })

      if (!res.ok) {
        const json = await res.json().catch(() => ({}))
        throw new Error((json as any).error || "Server error")
      }

      form.reset()
      successMsg?.classList.remove("hidden")
    } catch (err) {
      console.error(err)
      errorMsg?.classList.remove("hidden")
    } finally {
      btn.disabled = false
      btn.textContent = "Send message"
    }
  })
</script>
