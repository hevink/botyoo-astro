---
import { getCollection } from "astro:content"
import Layout from "../../layouts/Layout.astro"

const allDocs = await getCollection("help")

const sorted = allDocs.sort((a, b) => {
  const catCompare = a.data.category.localeCompare(b.data.category)
  if (catCompare !== 0) return catCompare
  return a.data.order - b.data.order
})

const byCategory = sorted.reduce<Record<string, typeof sorted>>((acc, doc) => {
  const cat = doc.data.category
  if (!acc[cat]) acc[cat] = []
  acc[cat].push(doc)
  return acc
}, {})

const categories = Object.keys(byCategory)

// Popular articles, ordered by the `popular` frontmatter field.
const popular = allDocs
  .filter((d) => typeof d.data.popular === "number")
  .sort((a, b) => (a.data.popular ?? 99) - (b.data.popular ?? 99))
  .slice(0, 6)

// Lucide icon paths (inner SVG markup), matching the site's two-tone style.
const ICONS: Record<string, string> = {
  rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  zap: '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
  "book-open": '<path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>',
  inbox: '<polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>',
  "credit-card": '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>',
  plug: '<path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z"/>',
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  file: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>',
}

const CATEGORY_META: Record<string, { icon: string; tint: string; desc: string }> = {
  "Getting Started":   { icon: "rocket",      tint: "text-sky-400",     desc: "Set up your account and launch your first automation." },
  Automations:         { icon: "zap",         tint: "text-amber-400",   desc: "Triggers, flows, gates, and follow-ups explained." },
  "How-To Guides":     { icon: "book-open",   tint: "text-violet-400",  desc: "Step-by-step walkthroughs for every feature." },
  "Inbox & Contacts":  { icon: "inbox",       tint: "text-emerald-400", desc: "Manage conversations, contacts, and campaigns." },
  "Account & Billing": { icon: "credit-card", tint: "text-rose-400",    desc: "Plans, payments, and account management." },
  Integrations:        { icon: "plug",        tint: "text-blue-400",  desc: "Connect teams, workspaces, AI, and MCP clients." },
  Troubleshooting:     { icon: "wrench",      tint: "text-orange-400",  desc: "Fix issues and understand platform limits." },
}

const searchData = sorted.map((d) => ({
  slug: d.id,
  title: d.data.title,
  description: d.data.description,
  category: d.data.category,
}))
---

<Layout
  title="Help Center - Botyoo"
  description="Find answers, guides, and documentation for Botyoo."
>
  <!-- Hero with gradient backdrop -->
  <section class="relative border-b border-border">
    <div
      class="pointer-events-none absolute inset-0 -z-10 opacity-70"
      style="background: radial-gradient(60% 120% at 50% -10%, color-mix(in oklch, var(--color-primary) 22%, transparent), transparent 70%);"
    >
    </div>

    <div class="mx-auto max-w-3xl px-6 pt-36 pb-16 text-center">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-border bg-card/60 px-3 py-1 text-xs font-medium text-muted-foreground shadow-sm backdrop-blur">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.93 4.93 4.24 4.24"/><path d="m14.83 9.17 4.24-4.24"/><path d="m14.83 14.83 4.24 4.24"/><path d="m9.17 14.83-4.24 4.24"/><circle cx="12" cy="12" r="4"/></svg>
        Help Center
      </div>

      <h1 class="text-foreground text-balance text-4xl font-semibold tracking-tight md:text-5xl">
        How can we help?
      </h1>
      <p class="text-muted-foreground mx-auto mt-4 max-w-md text-balance">
        Search our guides or browse by topic to get the most out of Botyoo.
      </p>

      <!-- Search -->
      <div class="relative mx-auto mt-8 max-w-xl" id="search-container">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground pointer-events-none"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          id="help-search"
          type="text"
          placeholder="Search for articles…"
          autocomplete="off"
          class="bg-card ring-border h-14 w-full rounded-2xl pl-12 pr-20 text-base text-foreground placeholder:text-muted-foreground shadow-lg shadow-black/5 ring-1 transition focus:outline-none focus:ring-2 focus:ring-primary"
        />
        <kbd class="absolute right-4 top-1/2 -translate-y-1/2 hidden rounded border border-border bg-muted px-1.5 py-0.5 text-[11px] text-muted-foreground sm:block">⌘K</kbd>
        <div
          id="search-results"
          class="bg-card ring-border absolute left-0 right-0 top-full z-30 mt-2 hidden max-h-[60vh] overflow-y-auto rounded-2xl text-left shadow-xl ring-1"
        >
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background pb-24 pt-16">
    <div class="mx-auto max-w-5xl px-6">

      <!-- Popular articles -->
      {popular.length > 0 && (
        <div class="mb-16">
          <h2 class="text-muted-foreground mb-4 flex items-center gap-2 text-xs font-semibold uppercase tracking-widest">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
            Popular articles
          </h2>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {popular.map((doc) => (
              <a
                href={`/help/${doc.id}`}
                class="bg-card ring-border hover:ring-primary/40 group flex items-start gap-3 rounded-xl p-4 shadow-sm ring-1 transition-all hover:shadow-md"
              >
                <div class="bg-muted text-primary flex h-9 w-9 shrink-0 items-center justify-center rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9 13h6"/><path d="M9 17h3"/></svg>
                </div>
                <div class="min-w-0">
                  <p class="text-foreground group-hover:text-primary truncate text-sm font-medium transition-colors">{doc.data.title}</p>
                  <p class="text-muted-foreground mt-0.5 line-clamp-2 text-xs leading-relaxed">{doc.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Collections / categories -->
      <h2 class="text-muted-foreground mb-4 text-xs font-semibold uppercase tracking-widest">
        Browse by topic
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {categories.map((category) => {
          const meta = CATEGORY_META[category] ?? { icon: "file", tint: "text-muted-foreground", desc: "" }
          const docs = byCategory[category]
          return (
            <div class="bg-card ring-border hover:ring-primary/40 group flex flex-col gap-4 rounded-2xl p-6 shadow-sm ring-1 transition-all hover:shadow-md">
              <div class="flex items-start gap-4">
                <div class={`bg-muted ${meta.tint} flex h-11 w-11 shrink-0 items-center justify-center rounded-xl`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[meta.icon]} />
                </div>
                <div class="min-w-0">
                  <p class="text-foreground text-base font-semibold leading-tight">{category}</p>
                  <p class="text-muted-foreground mt-1 text-sm leading-relaxed">{meta.desc}</p>
                </div>
              </div>

              <ul class="space-y-0.5 border-t border-border pt-3">
                {docs.slice(0, 4).map((doc) => (
                  <li>
                    <a href={`/help/${doc.id}`} class="text-muted-foreground hover:text-foreground hover:bg-foreground/5 -mx-2 flex items-center gap-2 rounded-lg px-2 py-1.5 text-sm transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-40"><path d="m9 18 6-6-6-6"/></svg>
                      <span class="truncate">{doc.data.title}</span>
                    </a>
                  </li>
                ))}
              </ul>

              {docs.length > 4 && (
                <a href={`/help/${docs[0].id}`} class="text-primary hover:opacity-80 mt-auto text-xs font-medium transition-opacity">
                  View all {docs.length} articles →
                </a>
              )}
            </div>
          )
        })}
      </div>

      <!-- CTA -->
      <div class="bg-card ring-border mt-16 rounded-2xl p-6 shadow-sm ring-1">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-4">
            <div class="bg-muted flex h-11 w-11 shrink-0 items-center justify-center rounded-xl text-xl">💬</div>
            <div>
              <p class="text-foreground font-semibold">Still need help?</p>
              <p class="text-muted-foreground mt-0.5 text-sm">Can't find what you're looking for? Our team is happy to help.</p>
            </div>
          </div>
          <a
            href="mailto:support@botyoo.com"
            class="btn btn-primary btn-sm shrink-0"
          >
            Contact Support
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script define:vars={{ searchData }}>
  const input = document.getElementById("help-search")
  const box   = document.getElementById("search-results")
  const wrap  = document.getElementById("search-container")

  function render(q) {
    if (!q) { box.classList.add("hidden"); box.innerHTML = ""; return }
    const hits = searchData.filter(
      (d) => d.title.toLowerCase().includes(q) || d.description.toLowerCase().includes(q)
    )
    if (!hits.length) {
      box.innerHTML = `<div class="px-4 py-6 text-center text-sm text-muted-foreground">No results for "<strong>${input.value}</strong>"</div>`
    } else {
      box.innerHTML = hits.map((d) => `
        <a href="/help/${d.slug}" class="flex items-center gap-3 border-b border-border px-4 py-3 text-sm transition-colors hover:bg-foreground/5 last:border-0">
          <div class="min-w-0 flex-1">
            <p class="truncate font-medium text-foreground">${d.title}</p>
            <p class="truncate text-xs text-muted-foreground">${d.description}</p>
          </div>
          <span class="bg-card ring-border shrink-0 rounded-md px-2 py-0.5 text-xs text-muted-foreground ring-1">${d.category}</span>
        </a>`
      ).join("")
    }
    box.classList.remove("hidden")
  }

  input.addEventListener("input", () => render(input.value.trim().toLowerCase()))

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") { e.preventDefault(); input.focus() }
    if (e.key === "Escape") { input.blur(); box.classList.add("hidden") }
  })

  document.addEventListener("click", (e) => {
    if (!wrap.contains(e.target)) box.classList.add("hidden")
  })
</script>
