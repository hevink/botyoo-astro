import CrmSection from "../components/CrmSection.astro"
import StatsGrid from "../components/StatsGrid.astro"
import Faqs from "../components/Faqs.astro"
import Reviews from "../components/Reviews.astro"
import CtaBanner from "../components/CtaBanner.astro"
---

<Layout
  title="Botyoo — Turn every Instagram follower into a lead"
  description="Botyoo is a complete Instagram lead engine: capture every comment as a lead, store them in a real CRM, build no-code DM flows, and run campaigns that sell."
>
  <main>
    <Hero />
    <FeatureCallout />
    <CrmSection />
    <StatsGrid />
    <Reviews />
    <CtaBanner />
    <Faqs />
  </main>
</Layout>
