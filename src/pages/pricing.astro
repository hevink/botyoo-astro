---
import Layout from "../layouts/Layout.astro"
import SolutionFaq from "../components/SolutionFaq.astro"

// Same plan data as botyoo-landing's pricing page, ported to Astro.
interface PriceByCurrency {
  INR: { monthly: string; quarterly: string; annually: string }
  USD: { monthly: string; quarterly: string; annually: string }
}

interface Plan {
  name: string
  price: PriceByCurrency | string
  originalPrice?: PriceByCurrency
  description: string
  capacity: string[]
  features: string[]
  isRecommended: boolean
  buttonText: string
}

const plans: Plan[] = [
  {
    name: "PRO Plan",
    price: {
      INR: { monthly: "₹399", quarterly: "₹349", annually: "₹299" },
      USD: { monthly: "$20", quarterly: "$18", annually: "$15" },
    },
    originalPrice: {
      INR: { monthly: "₹599", quarterly: "₹549", annually: "₹499" },
      USD: { monthly: "$35", quarterly: "$33", annually: "$30" },
    },
    description:
      "Perfect for content creators and influencers who want to grow their Instagram presence.",
    capacity: [],
    features: [
      "1 Instagram account (1 workspace)",
      "1 team member",
      "Unlimited automations & DMs",
      "10,000 contacts · 1,000 active / mo",
      "10 campaigns / mo",
      "All automation types (comment, story, IG Live, share, Click-to-DM)",
      "Visual Flow Builder + 25+ templates",
      "Contacts CRM, analytics & link tracking",
      "API access & API keys",
      "MCP server (Claude / AI assistant control)",
      "Email support",
    ],
    isRecommended: false,
    buttonText: "Get started Now",
  },
  {
    name: "PREMIUM Plan",
    price: {
      INR: { monthly: "₹599", quarterly: "₹549", annually: "₹499" },
      USD: { monthly: "$35", quarterly: "$33", annually: "$30" },
    },
    originalPrice: {
      INR: { monthly: "₹1199", quarterly: "₹1149", annually: "₹1099" },
      USD: { monthly: "$50", quarterly: "$48", annually: "$45" },
    },
    description:
      "Designed for brands and businesses with multiple accounts and advanced needs analytics.",
    capacity: [],
    features: [
      "Everything in Pro, plus:",
      "3 Instagram accounts (3 workspaces)",
      "5 team members",
      "Unlimited contacts · 15,000 active / mo",
      "Unlimited campaigns / mo",
      "Real-time shared team inbox",
      "Grow followers & capture emails in-DM",
      "Priority in queue",
      "API access & API keys",
      "MCP server (Claude / AI assistant control)",
    ],
    isRecommended: true,
    buttonText: "Get started Now",
  },
  {
    name: "Enterprise",
    price: "Contact us",
    description:
      "For agencies and large businesses managing multiple accounts with advanced customization.",
    capacity: [],
    features: [
      "Everything in Premium",
      "Unlimited team members",
      "Advanced custom chatbot",
      "Advanced automation rules",
      "Visual Flow Builder (unlimited steps)",
      "White-label options",
      "Priority support",
    ],
    isRecommended: false,
    buttonText: "Contact sales",
  },
]

const periods = [
  { value: "monthly", label: "Monthly" },
  { value: "quarterly", label: "Quarterly" },
  { value: "annually", label: "Yearly" },
] as const

type Period = (typeof periods)[number]["value"]

const defaultPeriod: Period = "annually"

const stripCurrency = (s: string) => {
  const match = s.match(/(\d+)/)
  return match ? parseInt(match[1], 10) : 0
}

// Always display USD prices
type Currency = { monthly: string; quarterly: string; annually: string }

const usdPrice = (plan: Plan): Currency =>
  typeof plan.price === "string"
    ? { monthly: plan.price, quarterly: plan.price, annually: plan.price }
    : plan.price.USD

const usdOriginalPrice = (plan: Plan): Currency | undefined =>
  plan.originalPrice ? plan.originalPrice.USD : undefined

const discountFor = (plan: Plan, p: Period) => {
  const orig = usdOriginalPrice(plan)
  if (!orig || typeof plan.price === "string") return 0
  const current = stripCurrency(usdPrice(plan)[p])
  const original = stripCurrency(orig[p])
  if (!original) return 0
  return Math.round(((original - current) / original) * 100)
}

// ── Compare Plans table ──────────────────────────────────────────────────────
interface CompareRow {
  label: string
  pro: boolean
  premium: boolean
  enterprise: boolean
}

const compareRows: CompareRow[] = [
  { label: "Comment-to-DM & keyword automation", pro: true, premium: true, enterprise: true },
  { label: "Story reply & story mention automation", pro: true, premium: true, enterprise: true },
  { label: "IG Live comment automation", pro: true, premium: true, enterprise: true },
  { label: "Post-share & Click-to-DM ad automation", pro: true, premium: true, enterprise: true },
  { label: "Comment automation on any post", pro: true, premium: true, enterprise: true },
  { label: "Multi-language keyword triggers", pro: true, premium: true, enterprise: true },
  { label: "In-DM email capture", pro: true, premium: true, enterprise: true },
  { label: "Contacts CRM with tags & segments", pro: true, premium: true, enterprise: true },
  { label: "Visual drag-and-drop Flow Builder", pro: true, premium: true, enterprise: true },
  { label: "25+ ready-made automation templates", pro: true, premium: true, enterprise: true },
  { label: "A/B testing & conditional branching", pro: true, premium: true, enterprise: true },
  { label: "DM campaigns (broadcast & retargeting)", pro: true, premium: true, enterprise: true },
  { label: "Detailed analytics & link tracking", pro: true, premium: true, enterprise: true },
  { label: "Refer & earn rewards", pro: true, premium: true, enterprise: true },
  { label: "Multiple team members", pro: false, premium: true, enterprise: true },
  { label: "Real-time shared team inbox", pro: false, premium: true, enterprise: true },
  { label: "Grow followers (send links to followers only)", pro: false, premium: true, enterprise: true },
  { label: "In-DM email & phone capture", pro: false, premium: true, enterprise: true },
  { label: "Priority in queue", pro: false, premium: true, enterprise: true },
  { label: "Advanced custom chatbot", pro: false, premium: false, enterprise: true },
  { label: "Advanced automation rules", pro: false, premium: false, enterprise: true },
  { label: "API access & API keys", pro: true, premium: true, enterprise: true },
  { label: "MCP server (Claude / AI assistant control)", pro: true, premium: true, enterprise: true },
  { label: "White-label options", pro: false, premium: false, enterprise: true },
  { label: "Priority support", pro: false, premium: false, enterprise: true },
]

// ── Pricing FAQs ─────────────────────────────────────────────────────────────
const pricingFaqs = [
  {
    q: "Can I upgrade or downgrade my plan later?",
    a: "Yes. You can switch plans at any time from your billing settings. Upgrades take effect immediately, and any change is prorated for your current billing period.",
  },
  {
    q: "What counts as an 'active contact'?",
    a: "An active contact is a unique person your automations engage with in a given month (for example, someone who triggers a comment-to-DM or sends a DM). Your CRM can store far more contacts than that, the active limit only applies to people you actually message in the month, and it resets every month.",
  },
  {
    q: "Do unlimited automations and DMs really mean unlimited?",
    a: "Yes. Every paid plan includes unlimited automations and unlimited DMs, with no per-message fees. We meter on active contacts per month, not on message volume, so your costs stay predictable as you scale.",
  },
  {
    q: "Which billing periods do you offer?",
    a: "You can pay monthly, quarterly, or yearly. Quarterly and yearly billing come at a lower effective monthly rate, so longer terms save you money.",
  },
  {
    q: "Is Botyoo safe for my Instagram account?",
    a: "Yes. Botyoo runs entirely on the official Meta / Instagram API, we never ask for your password or use unofficial access. This keeps your account compliant and protected from the bans associated with grey-market automation tools.",
  },
  {
    q: "Can I connect more than one Instagram account?",
    a: "The Pro plan covers 1 Instagram account, Premium covers 3, and Enterprise scales to many more. Each connected account gets its own workspace so data and automations stay separate.",
  },
  {
    q: "What's the difference between Premium and Enterprise?",
    a: "Premium adds team collaboration (5 members, real-time shared inbox), grow-followers gating, and in-DM email capture — plus API access and API keys and the MCP server for AI assistants. Enterprise unlocks advanced automation rules, white-label options, unlimited team members, and priority support.",
  },
  {
    q: "Do you offer refunds?",
    a: "Yes. If Botyoo isn't the right fit, you can request a refund per our refund policy. See the refund page for eligibility and timelines.",
  },
]
---

<Layout
  title="Pricing - Botyoo"
  description="Botyoo pricing plans for Instagram DM automation. Unlimited DMs, automations, and follower growth for creators and brands."
>
  <main class="mx-auto mt-36 max-w-6xl">
    <div class="relative py-16">
      <div class="mx-auto max-w-5xl px-6">
        <h1
          class="text-foreground mx-auto mb-8 max-w-md text-center text-4xl font-semibold leading-10"
        >
          Grow 10x More Instagram Followers with Our Plans
        </h1>

        {/* Toggle */}
        <div class="flex items-center justify-center">
          <div
            id="period-toggle"
            data-period={defaultPeriod}
            class="bg-muted relative z-0 inline-flex w-fit items-center gap-1 rounded-xl border p-1"
          >
            {
              periods.map((p) => {
                const isSelected = p.value === defaultPeriod
                return (
                  <button
                    type="button"
                    data-period-option={p.value}
                    data-selected={isSelected ? "true" : "false"}
                    class:list={[
                      "relative z-10 flex cursor-pointer items-center gap-2 rounded-xl px-3 py-1 text-sm font-medium capitalize transition-colors",
                      isSelected
                        ? "bg-background border text-foreground"
                        : "text-muted-foreground hover:text-foreground",
                    ]}
                  >
                    <span>{p.label}</span>
                  </button>
                )
              })
            }
          </div>
        </div>

        {/* Plans grid */}
        <div class="@container relative mt-6">
          <div
            class="@4xl:max-w-full bg-background text-card-foreground relative mx-auto flex max-w-sm flex-col gap-6 rounded-xl border py-6 shadow-sm"
          >
            <div class="@4xl:grid-cols-3 grid">
              {
                plans.map((plan) => (
                  <div
                    data-plan
                    class={[
                      "bg-background border border-transparent",
                      plan.isRecommended
                        ? "border-foreground/10 rounded-xl @3xl:mx-0 @3xl:-my-3 -mx-1 shadow bg-muted"
                        : "",
                    ].join(" ")}
                  >
                    <div
                      class={
                        plan.isRecommended
                          ? "@3xl:py-3 @3xl:px-0 relative px-1"
                          : ""
                      }
                    >
                      {/* Header */}
                      <div class="@container/card-header grid auto-rows-min grid-rows-[auto_auto] items-start gap-1.5 p-8">
                        <div class="leading-none font-medium">{plan.name}</div>

                        {/* Price */}
                        <div class="mb-0.5 mt-2 flex min-h-10 items-center">
                          {typeof plan.price === "string" ? (
                            <div class="text-2xl font-semibold">
                              {plan.price}
                            </div>
                          ) : (
                            <div class="flex items-center gap-2 flex-wrap">
                              <div class="text-2xl font-semibold">
                                <span>$</span><span
                                  data-price
                                  data-monthly={stripCurrency(
                                    usdPrice(plan).monthly,
                                  )}
                                  data-quarterly={stripCurrency(
                                    usdPrice(plan).quarterly,
                                  )}
                                  data-annually={stripCurrency(
                                    usdPrice(plan).annually,
                                  )}
                                >{stripCurrency(usdPrice(plan)[defaultPeriod])}</span>
                                <span class="text-muted-foreground ml-1 text-base font-normal">
                                  / mo
                                </span>
                              </div>
                              {usdOriginalPrice(plan) && (
                                <>
                                  <div
                                    data-discount
                                    data-monthly={discountFor(plan, "monthly")}
                                    data-quarterly={discountFor(
                                      plan,
                                      "quarterly",
                                    )}
                                    data-annually={discountFor(
                                      plan,
                                      "annually",
                                    )}
                                    class="bg-[#1347e6]/20 text-[#1347e6] border border-[#1347e6] px-1 py-0.5 rounded-lg text-sm font-medium"
                                  >
                                    {discountFor(plan, defaultPeriod)}% OFF
                                  </div>
                                  <div
                                    data-original
                                    data-monthly={usdOriginalPrice(plan)!.monthly}
                                    data-quarterly={usdOriginalPrice(plan)!.quarterly}
                                    data-annually={usdOriginalPrice(plan)!.annually}
                                    class="text-muted-foreground text-lg line-through"
                                  >
                                    {usdOriginalPrice(plan)![defaultPeriod]}
                                  </div>
                                </>
                              )}
                            </div>
                          )}
                        </div>

                        <div class="text-muted-foreground text-sm min-h-15">
                          {plan.description}
                        </div>

                        <div class="mt-4">
                          {plan.capacity.map((item) => (
                            <div class="text-muted-foreground text-sm flex items-center gap-2">
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="text-primary size-3"
                              >
                                <path d="M20 6 9 17l-5-5" />
                              </svg>
                              {item}
                            </div>
                          ))}
                        </div>
                      </div>

                      {/* CTA */}
                      <div
                        class={[
                          "border-y px-8 py-4",
                          plan.isRecommended ? "@3xl:mx-0 -mx-1" : "",
                        ].join(" ")}
                      >
                        <button
                          type="button"
                          data-plan-cta
                          data-plan-name={plan.name}
                          data-plan-price={
                            typeof plan.price === "string" ? plan.price : ""
                          }
                          class={[
                            "btn w-full",
                            plan.isRecommended ? "btn-primary" : "btn-secondary",
                          ].join(" ")}
                        >
                          {plan.buttonText}
                        </button>
                      </div>

                      {/* Features */}
                      <ul role="list" class="space-y-3 p-8">
                        {plan.features.map((feature) => (
                          <li class="flex items-start gap-2">
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="3.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              class="text-primary size-3 mt-[0.3rem] shrink-0"
                            >
                              <path d="M20 6 9 17l-5-5" />
                            </svg>
                            {feature}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Compare Plans */}
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="max-w-lg md:mx-auto md:text-center">
          <h2 class="text-foreground text-4xl font-semibold">Compare Plans</h2>
          <p class="text-muted-foreground mt-3 text-sm">
            Every plan includes unlimited automations and unlimited DMs. Here's how the tiers stack up.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-3xl overflow-x-auto">
          <div class="grid min-w-[680px] grid-cols-[1.6fr_2.4fr]">
            {/* Benefits column */}
            <div>
              <div class="h-18 flex items-center">
                <div class="text-lg font-medium">Features</div>
              </div>
              {
                compareRows.map((row) => (
                  <div class="flex h-14 items-center border-t max-md:text-sm">
                    <div>{row.label}</div>
                  </div>
                ))
              }
            </div>

            {/* Plans wrapper */}
            <div class="bg-linear-to-b from-foreground/3 grid grid-cols-3 rounded-2xl [--color-border:color-mix(in_oklab,var(--color-foreground)6%,transparent)]">
              {/* Pro column */}
              <div>
                <div class="h-18 flex flex-col items-center justify-center gap-1 px-4 text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.287 1.288L3 12l5.8 1.9a2 2 0 0 1 1.288 1.287L12 21l1.9-5.8a2 2 0 0 1 1.287-1.288L21 12l-5.8-1.9a2 2 0 0 1-1.288-1.287Z"></path></svg>
                  <div class="text-sm font-medium">Pro</div>
                </div>
                {
                  compareRows.map((row) => (
                    <div class="flex h-14 items-center justify-center border-t px-6">
                      <div>
                        {row.pro ? (
                          <span class="bg-emerald-500/10 text-emerald-600 flex size-5 items-center justify-center rounded-full font-sans text-xs font-semibold">✓</span>
                        ) : (
                          <span class="bg-foreground/6.5 text-foreground/65 flex size-5 items-center justify-center rounded-full font-sans text-xs font-semibold">✗</span>
                        )}
                      </div>
                    </div>
                  ))
                }
              </div>

              {/* Premium column (highlighted) */}
              <div class="bg-card ring-foreground/5 my-2 rounded-lg shadow-lg shadow-black/10 ring-1">
                <div class="flex h-16 flex-col items-center justify-center gap-1 px-4 pt-2 text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gem size-4"><path d="M6 3h12l4 6-10 13L2 9Z"></path><path d="M11 3 8 9l4 13 4-13-3-6"></path><path d="M2 9h20"></path></svg>
                  <div class="text-sm font-medium">Premium</div>
                </div>
                {
                  compareRows.map((row) => (
                    <div class="flex h-14 items-center justify-center border-t px-6">
                      <div>
                        {row.premium ? (
                          <span class="bg-emerald-500/10 text-emerald-600 flex size-5 items-center justify-center rounded-full font-sans text-xs font-semibold">✓</span>
                        ) : (
                          <span class="bg-foreground/6.5 text-foreground/65 flex size-5 items-center justify-center rounded-full font-sans text-xs font-semibold">✗</span>
                        )}
                      </div>
                    </div>
                  ))
                }
              </div>

              {/* Enterprise column */}
              <div>
                <div class="h-18 flex flex-col items-center justify-center gap-1 px-4 text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path></svg>
                  <div class="text-sm font-medium">Enterprise</div>
                </div>
                {
                  compareRows.map((row) => (
                    <div class="flex h-14 items-center justify-center border-t px-6">
                      <div>
                        {row.enterprise ? (
                          <span class="bg-emerald-500/10 text-emerald-600 flex size-5 items-center justify-center rounded-full font-sans text-xs font-semibold">✓</span>
                        ) : (
                          <span class="bg-foreground/6.5 text-foreground/65 flex size-5 items-center justify-center rounded-full font-sans text-xs font-semibold">✗</span>
                        )}
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* FAQs */}
    <SolutionFaq items={pricingFaqs} />
  </main>
</Layout>

<script>
  type Period = "monthly" | "quarterly" | "annually"

  const toggle = document.getElementById("period-toggle")
  if (toggle) {
    const options = Array.from(
      toggle.querySelectorAll<HTMLButtonElement>("[data-period-option]"),
    )

    const priceNodes =
      document.querySelectorAll<HTMLElement>("[data-price]")
    const discountNodes =
      document.querySelectorAll<HTMLElement>("[data-discount]")
    const originalNodes =
      document.querySelectorAll<HTMLElement>("[data-original]")

    const setPeriod = (period: Period) => {
      toggle.dataset.period = period

      options.forEach((opt) => {
        const isSelected = opt.dataset.periodOption === period
        opt.dataset.selected = isSelected ? "true" : "false"
        if (isSelected) {
          opt.classList.add("bg-background", "border", "text-foreground")
          opt.classList.remove(
            "text-muted-foreground",
            "hover:text-foreground",
          )
        } else {
          opt.classList.remove("bg-background", "border", "text-foreground")
          opt.classList.add("text-muted-foreground", "hover:text-foreground")
        }
      })

      priceNodes.forEach((node) => {
        const val = node.dataset[period]
        if (val != null) node.textContent = val
      })

      discountNodes.forEach((node) => {
        const val = node.dataset[period]
        if (val != null) node.textContent = `${val}% OFF`
      })

      originalNodes.forEach((node) => {
        const val = node.dataset[period]
        if (val != null) node.textContent = val
      })

      if (period === "quarterly" || period === "annually") {
        fireConfetti()
      }
    }

    options.forEach((opt) => {
      opt.addEventListener("click", () => {
        const period = opt.dataset.periodOption as Period
        if (period) setPeriod(period)
      })
    })
  }

  // Lightweight confetti burst (no external dependency)
  function fireConfetti() {
    const colors = [
      "#1347e6",
      "#22c55e",
      "#f59e0b",
      "#ec4899",
      "#8b5cf6",
      "#06b6d4",
    ]
    const count = 120
    const container = document.createElement("div")
    container.style.cssText =
      "position:fixed;inset:0;pointer-events:none;z-index:9999;overflow:hidden"
    document.body.appendChild(container)

    const originX = window.innerWidth / 2
    const originY = window.innerHeight * 0.35

    for (let i = 0; i < count; i++) {
      const piece = document.createElement("span")
      const size = 6 + Math.random() * 6
      const angle = Math.random() * Math.PI * 2
      const velocity = 150 + Math.random() * 300
      const dx = Math.cos(angle) * velocity
      const dy = Math.sin(angle) * velocity - 200
      const rot = Math.random() * 720 - 360
      const color = colors[Math.floor(Math.random() * colors.length)]

      piece.style.cssText = `
        position:absolute;
        left:${originX}px;
        top:${originY}px;
        width:${size}px;
        height:${size * 0.4}px;
        background:${color};
        border-radius:2px;
        transform:translate(-50%,-50%) rotate(0deg);
        opacity:1;
        will-change:transform,opacity;
      `
      container.appendChild(piece)

      const duration = 900 + Math.random() * 600
      piece.animate(
        [
          {
            transform: `translate(-50%,-50%) rotate(0deg)`,
            opacity: 1,
          },
          {
            transform: `translate(calc(-50% + ${dx}px), calc(-50% + ${dy + 400}px)) rotate(${rot}deg)`,
            opacity: 0,
          },
        ],
        {
          duration,
          easing: "cubic-bezier(.2,.7,.3,1)",
          fill: "forwards",
        },
      )
    }

    setTimeout(() => container.remove(), 1800)
  }
</script>
