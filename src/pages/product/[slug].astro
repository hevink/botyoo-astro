---
import Layout from "../../layouts/Layout.astro"
import SolutionHero from "../../components/SolutionHero.astro"
import SolutionFaq from "../../components/SolutionFaq.astro"
import CtaBanner from "../../components/CtaBanner.astro"
import UseCases from "../../components/UseCases.astro"
import ProductFeatureRow from "../../components/ProductFeatureRow.astro"
import { products } from "../../data/products"

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }))
}

const { product } = Astro.props

// Lucide icon inner-paths for the tools + benefits grids.
const icons: Record<string, string> = {
  send: '<path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/>',
  target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  flow: '<rect width="6" height="4" x="2" y="2" rx="1"/><rect width="6" height="4" x="16" y="10" rx="1"/><rect width="6" height="4" x="2" y="18" rx="1"/><path d="M8 4h3a1 1 0 0 1 1 1v10a1 1 0 0 0 1 1h3"/><path d="M8 20h3a1 1 0 0 0 1-1v-3"/>',
  chart: '<path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/>',
  inbox: '<polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>',
  user: '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  folder: '<path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>',
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  message: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  form: '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M8 10h8"/><path d="M8 14h5"/><path d="M12 17.5h4"/>',
  tag: '<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>',
  eye: '<path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/>',
  bolt: '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
  trend: '<path d="M16 7h6v6"/><path d="m22 7-8.5 8.5-5-5L2 17"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>',
  heart: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>',
  share: '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/>',
  click: '<path d="M14 4.1 12 6"/><path d="m5.1 8-2.9-.8"/><path d="m6 12-1.9 2"/><path d="M7.2 2.2 8 5.1"/><path d="M9.037 9.69a.498.498 0 0 1 .653-.653l11 4.5a.5.5 0 0 1-.074.949l-4.349 1.041a1 1 0 0 0-.74.739l-1.04 4.35a.5.5 0 0 1-.95.074z"/>',
}
---

<Layout
  title={`${product.eyebrow} - Botyoo`}
  description={product.description}
>
  <SolutionHero
    eyebrow={product.eyebrow}
    title={product.title}
    highlight={product.highlight}
    description={product.description}
  />

  <main class="pb-12">
    {/* What is X — illustrative feature rows */}
    <section class="bg-background py-16 md:py-24">
      <div class="mx-auto max-w-2xl px-6 text-balance text-center">
        <span class="text-primary font-mono text-sm uppercase">Overview</span>
        <h2 class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
          {product.featuresHeading}
        </h2>
        <p class="text-muted-foreground mx-auto mt-4 max-w-xl text-balance text-lg">
          {product.featuresSub}
        </p>
      </div>

      <div class="mx-auto mt-14 max-w-5xl space-y-16 px-6 md:mt-20 md:space-y-24">
        {
          product.features.map((f, i) => (
            <ProductFeatureRow
              index={i}
              title={f.title}
              desc={f.desc}
              visual={f.visual}
            />
          ))
        }
      </div>
    </section>

    {/* Use cases */}
    <section class="bg-background border-t border-border py-16 md:py-24">
      <div class="mx-auto max-w-4xl px-6">
        <div class="mb-12 max-w-2xl text-balance md:mb-16">
          <span class="text-primary font-mono text-sm uppercase">Use cases</span>
          <h2 class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
            {product.useCasesHeading}
          </h2>
          <p class="text-muted-foreground mt-4 max-w-xl text-balance text-lg">
            {product.useCasesSub}
          </p>
        </div>
        <UseCases items={product.useCases} />
      </div>
    </section>

    {/* Tools included */}
    <section class="bg-background border-t border-border py-16 md:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="mx-auto mb-12 max-w-2xl text-balance text-center md:mb-16">
          <span class="text-primary font-mono text-sm uppercase">What's included</span>
          <h2 class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
            Everything you need, built in
          </h2>
        </div>
        <div class="grid gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-4">
          {
            product.tools.map((tool) => (
              <div class="bg-background flex flex-col gap-4 p-6">
                <span class="flex size-10 items-center justify-center rounded-lg bg-foreground/5 ring-1 ring-foreground/10">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-primary size-5"
                    set:html={icons[tool.icon]}
                  />
                </span>
                <div>
                  <h3 class="text-foreground font-medium">{tool.title}</h3>
                  <p class="text-muted-foreground mt-1.5 text-sm leading-relaxed">
                    {tool.desc}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* Numbered steps */}
    <section class="bg-background border-t border-border py-16 md:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="mx-auto mb-12 max-w-2xl text-balance text-center md:mb-16">
          <span class="text-primary font-mono text-sm uppercase">How it works</span>
          <h2 class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
            {product.stepsHeading}
          </h2>
          <p class="text-muted-foreground mx-auto mt-4 max-w-xl text-balance text-lg">
            {product.stepsSub}
          </p>
        </div>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {
            product.steps.map((step, i) => (
              <div class="relative">
                <span class="text-foreground flex size-9 items-center justify-center rounded-full bg-foreground/8 text-sm font-semibold ring-1 ring-foreground/10">
                  {i + 1}
                </span>
                <h3 class="text-foreground mt-4 font-semibold">{step.title}</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                  {step.desc}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* Benefits */}
    <section class="bg-background border-t border-border py-16 md:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="mx-auto mb-12 max-w-2xl text-balance text-center md:mb-16">
          <span class="text-primary font-mono text-sm uppercase">Why Botyoo</span>
          <h2 class="text-foreground mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
            {product.benefitsHeading}
          </h2>
        </div>
        <div class="grid gap-8 md:grid-cols-3">
          {
            product.benefits.map((b) => (
              <div class="bg-card ring-border rounded-2xl p-6 shadow-sm shadow-black/5 ring-1">
                <span class="flex size-10 items-center justify-center rounded-lg bg-foreground/5 ring-1 ring-foreground/10">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-primary size-5"
                    set:html={icons[b.icon]}
                  />
                </span>
                <h3 class="text-foreground mt-4 text-lg font-semibold">{b.title}</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                  {b.desc}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* FAQ */}
    <div class="border-t border-border">
      <SolutionFaq items={product.faqs} />
    </div>

    {/* Bottom CTA */}
    <CtaBanner
      title={product.cta}
      ctaText="Start building free"
      note="Set up in under 5 minutes · No credit card needed"
    />
  </main>
</Layout>
