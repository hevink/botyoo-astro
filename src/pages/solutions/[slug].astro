---
import Layout from "../../layouts/Layout.astro"
import { solutions } from "../../data/solutions"

export function getStaticPaths() {
  return solutions.map((s) => ({
    params: { slug: s.slug },
    props: { solution: s },
  }))
}

const { solution } = Astro.props
---

<Layout
  title={`${solution.title} - Botyoo`}
  description={solution.description}
>
  <main class="pt-28 pb-28">
    <div class="mx-auto max-w-4xl px-6">

      {/* Hero */}
      <section class="py-12 border-b border-border">
        <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-3">
          {solution.tag}
        </p>
        <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-foreground max-w-2xl leading-tight">
          {solution.title}
        </h1>
        <p class="mt-4 text-lg text-muted-foreground max-w-xl leading-relaxed">
          {solution.description}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="https://app.botyoo.com/dashboard"
            class="inline-flex items-center gap-2 rounded-lg bg-foreground text-background px-5 py-2.5 text-sm font-medium hover:bg-foreground/90 transition-colors"
          >
            Get started free
          </a>
          <a
            href="/pricing"
            class="inline-flex items-center gap-2 rounded-lg border border-border bg-card text-foreground px-5 py-2.5 text-sm font-medium hover:bg-muted/50 transition-colors"
          >
            See pricing
          </a>
        </div>
      </section>

      {/* How it works */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          How it works
        </h2>
        <div class="space-y-8">
          {solution.steps.map((step, i) => (
            <div class="flex gap-6 items-start">
              <div class="shrink-0 w-8 h-8 rounded-full bg-foreground/8 flex items-center justify-center text-sm font-semibold text-foreground">
                {i + 1}
              </div>
              <div>
                <p class="font-semibold text-foreground">{step.title}</p>
                <p class="text-muted-foreground mt-1 text-sm leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* Use cases */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          Use cases
        </h2>
        <div class="grid sm:grid-cols-2 gap-px bg-border border border-border rounded-xl overflow-hidden">
          {solution.useCases.map((uc) => (
            <div class="bg-background p-5">
              <p class="font-semibold text-sm text-foreground">{uc.title}</p>
              <p class="text-xs text-muted-foreground mt-1.5 leading-relaxed">{uc.desc}</p>
            </div>
          ))}
        </div>
      </section>

      {/* FAQ */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          FAQ
        </h2>
        <div class="divide-y divide-border" id="faq">
          {solution.faqs.map((faq) => (
            <div class="faq-item py-4">
              <button
                type="button"
                class="faq-trigger w-full flex items-center justify-between text-left gap-4 text-sm font-medium text-foreground"
              >
                {faq.q}
                <svg
                  class="faq-icon shrink-0 w-4 h-4 text-muted-foreground transition-transform duration-200"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" />
                </svg>
              </button>
              <div class="faq-body hidden pt-3">
                <p class="text-sm text-muted-foreground leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* Bottom CTA */}
      <section class="py-16 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <p class="text-lg font-semibold text-foreground">{solution.cta}</p>
          <p class="text-sm text-muted-foreground mt-1">Set up in under 5 minutes. No credit card needed.</p>
        </div>
        <a
          href="https://app.botyoo.com/dashboard"
          class="shrink-0 inline-flex items-center gap-2 rounded-lg bg-foreground text-background px-5 py-2.5 text-sm font-medium hover:bg-foreground/90 transition-colors"
        >
          Start building free →
        </a>
      </section>

    </div>
  </main>
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('.faq-item').forEach((item) => {
    item.querySelector<HTMLButtonElement>('.faq-trigger')?.addEventListener('click', () => {
      const body = item.querySelector<HTMLElement>('.faq-body')
      const icon = item.querySelector<SVGElement>('.faq-icon')
      body?.classList.toggle('hidden')
      icon?.classList.toggle('rotate-180')
    })
  })
</script>
