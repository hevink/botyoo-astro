---
import Layout from "../../layouts/Layout.astro"
import SolutionHero from "../../components/SolutionHero.astro"
import SolutionFaq from "../../components/SolutionFaq.astro"
import CtaBanner from "../../components/CtaBanner.astro"
import UseCases from "../../components/UseCases.astro"
import { solutions } from "../../data/solutions"

export function getStaticPaths() {
  return solutions.map((s) => ({
    params: { slug: s.slug },
    props: { solution: s },
  }))
}

const { solution } = Astro.props
---

<Layout
  title={`${solution.title} - Botyoo`}
  description={solution.description}
>
  <SolutionHero
    eyebrow={solution.tag}
    title={solution.title}
    description={solution.description}
  />
  <main class="pb-28">
    <div class="mx-auto max-w-4xl px-6">

      {/* How it works */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          How it works
        </h2>
        <div class="space-y-8">
          {solution.steps.map((step, i) => (
            <div class="flex gap-6 items-start">
              <div class="shrink-0 w-8 h-8 rounded-full bg-foreground/8 flex items-center justify-center text-sm font-semibold text-foreground">
                {i + 1}
              </div>
              <div>
                <p class="font-semibold text-foreground">{step.title}</p>
                <p class="text-muted-foreground mt-1 text-sm leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* Use cases */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          Use cases
        </h2>
        <UseCases items={solution.useCases} />
      </section>

      {/* FAQ */}
      <SolutionFaq items={solution.faqs} />

    </div>

    {/* Bottom CTA */}
    <CtaBanner
      title={solution.cta}
      ctaText="Start building free"
      note="Set up in under 5 minutes. No credit card needed."
    />
  </main>
</Layout>
