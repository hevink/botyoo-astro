---
import Layout from "../../layouts/Layout.astro"
import SolutionHero from "../../components/SolutionHero.astro"
import SolutionFaq from "../../components/SolutionFaq.astro"
import CtaBanner from "../../components/CtaBanner.astro"
import UseCases from "../../components/UseCases.astro"

const useCases = [
  {
    title: "Creator campaign funnels",
    desc: "Build comment-to-DM funnels for influencer campaigns. Every person who engages with a sponsored post becomes a capturable lead.",
  },
  {
    title: "Community management at scale",
    desc: "Automate the repetitive inbox work, FAQs, link requests, story replies, so your team focuses on conversations that actually need a human touch.",
  },
  {
    title: "Paid-to-DM capture",
    desc: "Run paid traffic to a post or story with a keyword CTA. Botyoo captures every responder as a lead, measuring paid-to-DM conversion directly.",
  },
  {
    title: "Bespoke AI flows per client",
    desc: "Configure Botyoo's AI to reply in each client's tone of voice. Superfan or luxury brand, the AI learns the personality and applies it consistently across every DM.",
  },
]

const faqs = [
  {
    q: "Can I manage multiple client Instagram accounts from one Botyoo login?",
    a: `Yes. Botyoo supports multiple workspaces, each tied to a separate Instagram account. You can switch between client workspaces from your dashboard without logging out. Each workspace has its own automations, contacts, and settings, fully isolated from others.`,
  },
  {
    q: "How do I show clients ROI from DM automation?",
    a: `Botyoo's analytics show DMs sent, link clicks, leads captured, and flow conversion rates per campaign. You can use this data to build client-facing reports. For deeper attribution, connect Botyoo to your tracking stack via webhooks and measure downstream conversions on your client's site.`,
  },
  {
    q: "Can Botyoo match a client's specific brand voice?",
    a: `Yes. Each workspace can be configured with custom AI instructions: tone, language, topics to avoid, and example responses. An upscale wellness brand and a streetwear label can both run Botyoo, and each will sound exactly like themselves in every DM. You write the rules; the AI follows them.`,
  },
  {
    q: "Is Botyoo compliant with Meta's messaging policies for business accounts?",
    a: `Botyoo runs on Meta's official Messaging API, which means all automations operate within Instagram's permitted usage guidelines. We send DMs only to users who have opted in by initiating contact (commenting, using a keyword, or messaging first), which is exactly what Meta's policies require for automated outbound messaging.`,
  },
]
---

<Layout
  title="Botyoo for Agencies: Add Instagram DM Automation to Every Client Campaign"
  description="Botyoo gives agencies a white-label-friendly Instagram automation layer. Run funnels, capture leads, and prove ROI across all your clients, without adding headcount."
>
  <SolutionHero
    eyebrow="For Agencies"
    title="Add Instagram DM automation to"
    highlight="every client campaign."
    description="Botyoo gives agencies a white-label-friendly Instagram automation layer. Run funnels, capture leads, and prove ROI across all your clients, without adding headcount."
  />
  <main class="pb-28">
    <div class="mx-auto max-w-4xl px-6">

      {/* How it works */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-12">
          How it works
        </h2>

        <div class="space-y-20">

          {/* Step 1 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">1</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Setup</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Set up client funnels in minutes</h3>
              <p class="text-muted-foreground leading-relaxed">
                Duplicate proven templates across accounts. Each client gets their own flow, voice, and inbox, no bleed between workspaces. Onboard a new client in minutes, not days.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6">
              <p class="text-sm font-medium text-foreground mb-4">Client workspaces</p>
              <div class="space-y-2.5">
                <div class="flex items-center justify-between p-3 rounded-lg bg-foreground/5">
                  <div class="flex items-center gap-3">
                    <div class="size-7 rounded-md bg-foreground/10 flex items-center justify-center text-xs text-foreground/70 font-bold">NB</div>
                    <div>
                      <p class="text-xs font-medium text-foreground">NovaBrand Co.</p>
                      <p class="text-xs text-muted-foreground">4 active flows</p>
                    </div>
                  </div>
                  <span class="text-xs text-muted-foreground">Live</span>
                </div>
                <div class="flex items-center justify-between p-3 rounded-lg bg-foreground/5">
                  <div class="flex items-center gap-3">
                    <div class="size-7 rounded-md bg-foreground/10 flex items-center justify-center text-xs text-foreground/70 font-bold">PX</div>
                    <div>
                      <p class="text-xs font-medium text-foreground">Pixelwave Studio</p>
                      <p class="text-xs text-muted-foreground">2 active flows</p>
                    </div>
                  </div>
                  <span class="text-xs text-muted-foreground">Live</span>
                </div>
                <div class="flex items-center justify-between p-3 rounded-lg bg-foreground/5">
                  <div class="flex items-center gap-3">
                    <div class="size-7 rounded-md bg-foreground/10 flex items-center justify-center text-xs text-foreground/70 font-bold">GS</div>
                    <div>
                      <p class="text-xs font-medium text-foreground">GreenShift Foods</p>
                      <p class="text-xs text-muted-foreground">Setup in progress</p>
                    </div>
                  </div>
                  <span class="text-xs text-muted-foreground text-amber-400/80">Draft</span>
                </div>
              </div>
            </div>
          </div>

          {/* Step 2 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="md:order-2">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">2</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Reporting</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Track what actually converts</h3>
              <p class="text-muted-foreground leading-relaxed">
                See which posts drove DMs, how many leads were captured per flow, and which automations generated the most link clicks. Clean attribution data you can put directly into client reports.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6 md:order-1">
              <p class="text-sm font-medium text-foreground mb-4">Campaign analytics: NovaBrand Co.</p>
              <div class="space-y-3 text-xs">
                <div class="grid grid-cols-3 gap-3">
                  <div class="bg-foreground/5 rounded-lg p-3 text-center">
                    <p class="text-lg font-bold text-foreground">1,847</p>
                    <p class="text-muted-foreground mt-0.5">DMs sent</p>
                  </div>
                  <div class="bg-foreground/5 rounded-lg p-3 text-center">
                    <p class="text-lg font-bold text-foreground">643</p>
                    <p class="text-muted-foreground mt-0.5">Leads</p>
                  </div>
                  <div class="bg-foreground/5 rounded-lg p-3 text-center">
                    <p class="text-lg font-bold text-foreground">34.8%</p>
                    <p class="text-muted-foreground mt-0.5">CTR</p>
                  </div>
                </div>
                <div class="space-y-1.5 pt-1">
                  <div class="flex items-center justify-between">
                    <span class="text-muted-foreground">Top flow</span>
                    <span class="text-foreground/70">Summer LINK post</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-muted-foreground">Best open rate</span>
                    <span class="text-foreground/70">91.4%</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          {/* Step 3 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">3</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Management</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Manage every account in one place</h3>
              <p class="text-muted-foreground leading-relaxed">
                Switch between client workspaces from a single dashboard. Keep automations organized by client, share clean performance reports, and hand off accounts to team members without losing context.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6">
              <p class="text-sm font-medium text-foreground mb-4">Agency dashboard</p>
              <div class="space-y-3 text-xs">
                <div class="flex items-center gap-3 p-2.5 rounded-lg bg-foreground/5">
                  <div class="size-2 rounded-full bg-primary"></div>
                  <span class="text-foreground flex-1">NovaBrand: Summer campaign</span>
                  <span class="text-muted-foreground">Active</span>
                </div>
                <div class="flex items-center gap-3 p-2.5 rounded-lg bg-foreground/5">
                  <div class="size-2 rounded-full bg-primary"></div>
                  <span class="text-foreground flex-1">Pixelwave: Product drop flow</span>
                  <span class="text-muted-foreground">Active</span>
                </div>
                <div class="flex items-center gap-3 p-2.5 rounded-lg bg-foreground/5">
                  <div class="size-2 rounded-full bg-foreground/20"></div>
                  <span class="text-foreground flex-1">GreenShift: Lead gen setup</span>
                  <span class="text-muted-foreground">Draft</span>
                </div>
                <div class="border-t border-foreground/10 pt-2 flex justify-between">
                  <span class="text-muted-foreground">Total leads this month</span>
                  <span class="text-foreground font-medium">2,184</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

      {/* Use Cases */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          Key use cases
        </h2>
        <UseCases items={useCases} />
      </section>

      {/* FAQ */}
      <SolutionFaq items={faqs} />

      {/* Bottom CTA */}
    </div>

    <CtaBanner
      title="The service your clients need next."
      ctaText="Start building free"
      note="Set up in under 5 minutes. No credit card needed."
    />
  </main>
</Layout>
