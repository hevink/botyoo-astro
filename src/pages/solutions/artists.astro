---
import Layout from "../../layouts/Layout.astro"
import SolutionHero from "../../components/SolutionHero.astro"
import SolutionFaq from "../../components/SolutionFaq.astro"
import CtaBanner from "../../components/CtaBanner.astro"
import UseCases from "../../components/UseCases.astro"

const useCases = [
  {
    title: "Pre-save campaigns",
    desc: `Comment "PRESAVE" → DM with the Spotify/Apple pre-save link. Track who opted in and message them on release day.`,
  },
  {
    title: "Stream link delivery",
    desc: "New single, EP, or album drop? Send the stream link directly to fans via DM the moment it's live, no post burial, no link-in-bio friction.",
  },
  {
    title: "Merch and ticket drops",
    desc: "Build hype with a post, capture interest through comments, then DM the checkout link to everyone who signaled interest. Sell out faster.",
  },
  {
    title: "Fan segmentation",
    desc: "Tag fans by campaign, engagement level, or location. Send tour DMs only to fans in relevant cities. Superfan-only early access. Keep it personal at scale.",
  },
]

const faqs = [
  {
    q: "Can I use DMs to promote music without coming across as spam?",
    a: `Yes, because Botyoo only sends DMs to fans who opt in by interacting first (commenting, using a keyword, replying to a story). You're never cold-messaging strangers. Every person you DM already raised their hand, which means the message feels personal, not promotional.`,
  },
  {
    q: "How do pre-save campaigns work with Botyoo?",
    a: `Post a teaser with a call-to-action like "comment PRESAVE for the link." Botyoo instantly DMs each person the pre-save URL and tags them. On release day, you fire a campaign to everyone in that group with the stream link, closing the loop automatically.`,
  },
  {
    q: "Can I build a direct fan channel outside the algorithm?",
    a: `That's exactly what Botyoo's contact list is for. Every fan who interacts with your automations gets stored as a contact. You can DM the whole list anytime, for new releases, tour announcements, or merch drops, without relying on Instagram's feed algorithm to surface your post.`,
  },
  {
    q: "We're a label managing multiple artists, does Botyoo handle that?",
    a: `Yes. Botyoo supports multiple workspaces, so each artist gets their own separate account, automations, and contact list. Labels and management teams can switch between workspaces from one login without any crossover between fan data or flows.`,
  },
]
---

<Layout
  title="Botyoo for Artists & Labels: Drop Music Straight Into Fans' DMs"
  description="Your fans are already on Instagram. Botyoo helps you connect with them personally: pre-saves, stream links, merch drops, and tour announcements, all delivered via DM automatically."
>
  <SolutionHero
    eyebrow="For Artists & Labels"
    title="Drop your music straight into"
    highlight="your fans' DMs."
    description="Your fans are already on Instagram. Botyoo helps you connect with them personally: pre-saves, stream links, merch drops, and tour announcements, all delivered via DM automatically."
  />
  <main class="pb-28">
    <div class="mx-auto max-w-4xl px-6">

      {/* How it works */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-12">
          How it works
        </h2>

        <div class="space-y-20">

          {/* Step 1 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">1</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Identify</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Spot your real fans</h3>
              <p class="text-muted-foreground leading-relaxed">
                Anyone who comments, replies to a story, or drops a keyword gets tagged as a fan automatically. Build segments based on how they engage: superfans who comment every post vs. casual listeners who click links once in a while.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6">
              <p class="text-sm font-medium text-foreground mb-4">Fan segments</p>
              <div class="space-y-3">
                <div class="flex items-center justify-between p-3 rounded-lg bg-foreground/5">
                  <div>
                    <p class="text-xs font-medium text-foreground">Superfans</p>
                    <p class="text-xs text-muted-foreground">Commented on 3+ posts</p>
                  </div>
                  <span class="text-xs font-medium text-foreground bg-foreground/10 px-2 py-0.5 rounded-full">847</span>
                </div>
                <div class="flex items-center justify-between p-3 rounded-lg bg-foreground/5">
                  <div>
                    <p class="text-xs font-medium text-foreground">Pre-save crew</p>
                    <p class="text-xs text-muted-foreground">Used keyword "PRESAVE"</p>
                  </div>
                  <span class="text-xs font-medium text-foreground bg-foreground/10 px-2 py-0.5 rounded-full">2,341</span>
                </div>
                <div class="flex items-center justify-between p-3 rounded-lg bg-foreground/5">
                  <div>
                    <p class="text-xs font-medium text-foreground">Merch buyers</p>
                    <p class="text-xs text-muted-foreground">Clicked merch link</p>
                  </div>
                  <span class="text-xs font-medium text-foreground bg-foreground/10 px-2 py-0.5 rounded-full">312</span>
                </div>
              </div>
            </div>
          </div>

          {/* Step 2 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="md:order-2">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">2</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Release</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">DM your release directly</h3>
              <p class="text-muted-foreground leading-relaxed">
                The moment your track drops, Botyoo delivers the stream link, the merch URL, or the ticket page directly to opted-in fans via DM. No algorithm to fight. No feed post getting buried. It lands in their inbox.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6 md:order-1">
              <p class="text-xs text-muted-foreground mb-4">Release day DM to @fan_handle</p>
              <div class="space-y-3 text-xs">
                <div class="flex gap-2">
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-foreground/70 text-[9px]">AR</div>
                  <div class="bg-foreground/5 rounded-lg rounded-tl-none p-2.5 text-muted-foreground">
                    It's out 🎵 "Fading Signal" is live on all platforms right now.<br/><br/>
                    Stream it here → distrokid.com/fadingsignal<br/><br/>
                    Limited merch drops at midnight, you're on the early list 🖤
                  </div>
                </div>
                <div class="flex gap-2 justify-end">
                  <div class="bg-foreground/10 rounded-lg rounded-tr-none p-2.5 text-foreground">
                    YESSS been waiting for this 🔥🔥
                  </div>
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-foreground/70 text-[9px]">F</div>
                </div>
              </div>
            </div>
          </div>

          {/* Step 3 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">3</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Own your audience</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Build a fanbase you own</h3>
              <p class="text-muted-foreground leading-relaxed">
                Every fan who opts in becomes a contact you can reach directly, no algorithm gatekeeping your message. Segment by engagement, location, or campaign and send targeted DM blasts whenever you need to move tickets, merch, or streams.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6">
              <p class="text-sm font-medium text-foreground mb-4">DM campaign: Tour announcement</p>
              <div class="space-y-3 text-xs">
                <div class="flex justify-between items-center">
                  <span class="text-muted-foreground">Audience</span>
                  <span class="text-foreground/70">NYC + LA fans</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-muted-foreground">Contacts</span>
                  <span class="text-foreground/70">1,089</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-muted-foreground">Opened</span>
                  <span class="text-foreground/70">94.2%</span>
                </div>
                <div class="border-t border-foreground/10 pt-3">
                  <div class="bg-foreground/5 rounded-lg p-2.5 text-muted-foreground">
                    "Tour dates just dropped 🎤 NYC Nov 14 / LA Nov 18. Presale code: FANFIRST, grab yours before they're gone."
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

      {/* Use Cases */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          Key use cases
        </h2>
        <UseCases items={useCases} />
      </section>

      {/* FAQ */}
      <SolutionFaq items={faqs} />

    </div>

    {/* Bottom CTA */}
    <CtaBanner
      title="A direct line to your fans."
      ctaText="Start building free"
      note="Set up in under 5 minutes. No credit card needed."
    />
  </main>
</Layout>
