---
import Layout from "../../layouts/Layout.astro"
import SolutionHero from "../../components/SolutionHero.astro"
import SolutionFaq from "../../components/SolutionFaq.astro"
import CtaBanner from "../../components/CtaBanner.astro"
import UseCases from "../../components/UseCases.astro"

const useCases = [
  {
    title: "After-hours consultation capture",
    desc: "Patients DM at all hours. Botyoo responds instantly at 11pm just as well as 11am, so you never lose a lead to a slow reply from a competitor who responded first.",
  },
  {
    title: "Patient qualification flows",
    desc: "Collect treatment interest, budget range, and timeline through a natural DM conversation before your team ever picks up the phone.",
  },
  {
    title: "Lead recovery sequences",
    desc: "Re-engage inquiries that went cold with a timed follow-up: a seasonal offer, a new treatment announcement, or a simple check-in. Recover bookings without manual outreach.",
  },
  {
    title: "CRM sync",
    desc: "Push qualified lead data, name, Instagram handle, treatment interest, contact details, to your CRM or Google Sheet automatically via webhook. No copy-paste.",
  },
]

const faqs = [
  {
    q: "What exactly is Instagram automation for clinics?",
    a: `It means Botyoo handles the first layer of patient communication on Instagram automatically: replying to DMs, collecting intake information, and routing qualified leads to your team. You're not replacing your staff; you're making sure no inquiry slips through because it came in at midnight or during a busy clinic day.`,
  },
  {
    q: "How do I get Botyoo set up for my medspa?",
    a: `Connect your Instagram business account, pick a template (we have a ready-made clinic inquiry flow), customize the questions and your clinic's tone, and activate. Most practices are live within 10–15 minutes. No technical setup required. If you can type a DM, you can configure Botyoo.`,
  },
  {
    q: "How is this different from a generic chatbot?",
    a: `Generic chatbots are rigid, scripted, and obvious. Botyoo's AI replies naturally, adapts to what the patient says, and knows when to escalate to a human. You can instruct it with your clinic's voice, treatment menu, and what not to say. Patients get a professional, warm response, not a bot-shaped wall.`,
  },
  {
    q: "How long until we start seeing new consultation bookings?",
    a: `Most clinics see their first automatically-handled inquiry within hours of going live, assuming there's existing DM traffic from their Instagram content. If your account doesn't get many DMs yet, Botyoo also captures leads from comments on posts, so your content can start generating inquiries without people needing to initiate a DM first.`,
  },
]
---

<Layout
  title="Botyoo for Clinics & Medspas: Never Miss a Patient Inquiry Again"
  description="Botyoo replies to every Instagram DM in seconds, capturing patient interest, asking qualifying questions, and routing ready-to-book leads straight to your team."
>
  <SolutionHero
    eyebrow="For Clinics & Medspas"
    title="Never miss a"
    highlight="patient inquiry again."
    description="Botyoo replies to every Instagram DM in seconds, capturing patient interest, asking qualifying questions, and routing ready-to-book leads straight to your team."
  />
  <main class="pb-28">
    <div class="mx-auto max-w-4xl px-6">

      {/* How it works */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-12">
          How it works
        </h2>

        <div class="space-y-20">

          {/* Step 1 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">1</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Respond</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Respond to every inquiry instantly</h3>
              <p class="text-muted-foreground leading-relaxed">
                No more missed DMs after-hours or over the weekend. Botyoo responds in seconds, 24/7, in the patient's language. The first reply sets the tone: fast, professional, and warm.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6">
              <p class="text-xs text-muted-foreground mb-4">Instant DM reply, 11:47pm</p>
              <div class="space-y-3 text-xs">
                <div class="flex gap-2 justify-end">
                  <div class="bg-foreground/10 rounded-lg rounded-tr-none p-2.5 text-foreground">
                    Hi, I'm interested in lip filler. How much does it cost?
                  </div>
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-foreground/70 text-[9px]">P</div>
                </div>
                <div class="flex gap-2">
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-foreground/70 text-[9px]">CL</div>
                  <div class="bg-foreground/5 rounded-lg rounded-tl-none p-2.5 text-muted-foreground">
                    Hi! Thanks for reaching out to Clarity Aesthetics 💉 We'd love to help. Lip filler consultations start with a complimentary 15-min virtual call. Can I ask a couple of quick questions to get you set up?
                  </div>
                </div>
                <div class="flex items-center gap-2 text-muted-foreground pt-1">
                  <div class="size-2 rounded-full bg-primary"></div>
                  <span>Replied in 4 seconds</span>
                </div>
              </div>
            </div>
          </div>

          {/* Step 2 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="md:order-2">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">2</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Qualify</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Qualify automatically</h3>
              <p class="text-muted-foreground leading-relaxed">
                A short DM flow collects treatment interest, timeline, and contact details before any staff member gets involved. Only qualified, ready-to-book patients land in your team's queue.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6 md:order-1">
              <p class="text-xs text-muted-foreground mb-4">Qualification flow</p>
              <div class="space-y-3 text-xs">
                <div class="flex gap-2">
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-foreground/70 text-[9px]">CL</div>
                  <div class="bg-foreground/5 rounded-lg rounded-tl-none p-2.5 text-muted-foreground">
                    Which treatment are you most interested in?<br/>
                    A) Lip filler &nbsp; B) Botox &nbsp; C) Skin treatment &nbsp; D) Other
                  </div>
                </div>
                <div class="flex gap-2 justify-end">
                  <div class="bg-foreground/10 rounded-lg rounded-tr-none p-2.5 text-foreground">A</div>
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-foreground/70 text-[9px]">P</div>
                </div>
                <div class="flex gap-2">
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-foreground/70 text-[9px]">CL</div>
                  <div class="bg-foreground/5 rounded-lg rounded-tl-none p-2.5 text-muted-foreground">
                    When were you hoping to come in? This week, next week, or just exploring?
                  </div>
                </div>
                <div class="flex gap-2 justify-end">
                  <div class="bg-foreground/10 rounded-lg rounded-tr-none p-2.5 text-foreground">This week if possible</div>
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-foreground/70 text-[9px]">P</div>
                </div>
                <div class="flex items-center gap-2 text-muted-foreground pt-1">
                  <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  Lead qualified, routed to booking team
                </div>
              </div>
            </div>
          </div>

          {/* Step 3 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">3</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Handoff</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Hot leads land in your system</h3>
              <p class="text-muted-foreground leading-relaxed">
                Qualified patients sync to your CRM or Google Sheet with full profile data: treatment interest, timeline, and contact details. Your team picks up exactly where the automation left off, with full context.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6">
              <p class="text-sm font-medium text-foreground mb-4">New lead: ready to book</p>
              <div class="space-y-3 text-xs">
                <div class="bg-foreground/5 rounded-lg p-3 space-y-2">
                  <div class="flex justify-between">
                    <span class="text-muted-foreground">Instagram</span>
                    <span class="text-foreground/70">@patient_handle</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-muted-foreground">Treatment interest</span>
                    <span class="text-foreground/70">Lip filler</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-muted-foreground">Timeline</span>
                    <span class="text-foreground/70">This week</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-muted-foreground">Email</span>
                    <span class="text-foreground/70">Captured ✓</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-muted-foreground">Phone</span>
                    <span class="text-foreground/70">Captured ✓</span>
                  </div>
                </div>
                <div class="flex items-center gap-2 text-muted-foreground">
                  <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  Synced to CRM + team notified
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

      {/* Use Cases */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          Key use cases
        </h2>
        <UseCases items={useCases} />
      </section>

      {/* FAQ */}
      <SolutionFaq items={faqs} />

    </div>

    {/* Bottom CTA */}
    <CtaBanner
      title="Never miss a midnight inquiry."
      ctaText="Start building free"
      note="Set up in under 5 minutes. No credit card needed."
    />
  </main>
</Layout>
