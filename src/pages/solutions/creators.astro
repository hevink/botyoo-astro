---
import Layout from "../../layouts/Layout.astro"
import SolutionHero from "../../components/SolutionHero.astro"
import SolutionFaq from "../../components/SolutionFaq.astro"
import CtaBanner from "../../components/CtaBanner.astro"
import UseCases from "../../components/UseCases.astro"

const useCases = [
  {
    title: "Freebie delivery",
    desc: "Comment a keyword → instant DM with your PDF, checklist, or guide. No link-in-bio friction, no lost leads.",
  },
  {
    title: "Link in bio replacement",
    desc: "Stop sending people to a static page. Drive them to DMs instead, higher engagement, better tracking, real conversations.",
  },
  {
    title: "Story reply automation",
    desc: "Mention your lead magnet in a story. Everyone who replies gets a DM instantly, even at 3am when you're asleep.",
  },
  {
    title: "Course and offer promotion",
    desc: "Warm up your audience through DM conversations before pitching. Followers who reply are already engaged, they convert better.",
  },
]

const faqs = [
  {
    q: "Will Instagram flag my account for using automation?",
    a: `Botyoo connects through Meta's official API, so you're working within Instagram's permitted automation tools, not scraping or botting. This is the same infrastructure that major brands and agencies use. Following Meta's guidelines (like not spamming unsolicited DMs) keeps your account in good standing.`,
  },
  {
    q: "Can I use this to deliver different freebies to different audiences?",
    a: `Yes, each automation you create has its own keyword, message, and destination link. So you can run a "GUIDE" automation for one post and a "TEMPLATE" automation for another, and each sends the right thing to the right person. No mixing, no mistakes.`,
  },
  {
    q: "How does email list building through DMs actually work?",
    a: `After sending the initial freebie, your flow can ask a follow-up question like "Want me to email this too?" When someone replies with their address, Botyoo captures it and stores it as a contact. You can then export those emails or connect them to your email tool via Zapier or webhook.`,
  },
  {
    q: "Can I promote a paid course or offer through DM flows?",
    a: `Absolutely. Many creators use Botyoo to warm up leads with a freebie first, then follow up days later with a pitch for their paid offer. The sequence feels personal rather than spammy, which means higher open rates and better conversion compared to a cold link drop.`,
  },
]
---

<Layout
  title="Botyoo for Content Creators: Turn Engagement Into a Lead Machine"
  description="Stop manually replying to every comment. Botyoo turns your Instagram engagement into a 24/7 lead machine, delivering freebies, links, and offers while you're focused on creating."
>
  <SolutionHero
    eyebrow="For Content Creators"
    title="Your content works hard."
    highlight="Your DMs should too."
    description="Stop manually replying to every comment. Botyoo turns your Instagram engagement into a 24/7 lead machine, delivering freebies, links, and offers while you're focused on creating."
  />
  <main class="pb-28">
    <div class="mx-auto max-w-4xl px-6">

      {/* How it works */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-12">
          How it works
        </h2>

        <div class="space-y-20">

          {/* Step 1 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">1</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Trigger</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Comment triggers a DM</h3>
              <p class="text-muted-foreground leading-relaxed">
                Someone drops a keyword in your comments, "GUIDE", "LINK", "FREEBIE", and Botyoo fires a personalized DM to that person within seconds. Your freebie, your link, your offer. Delivered automatically.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6">
              <p class="text-xs text-muted-foreground mb-4">Comment detected → DM sent</p>
              <div class="space-y-3 text-sm">
                <div class="bg-foreground/5 rounded-lg p-3">
                  <p class="text-xs text-muted-foreground mb-1">Post caption</p>
                  <p class="text-foreground/80 text-xs">Comment <strong>"GUIDE"</strong> and I'll DM you my free 30-page content calendar 📅</p>
                </div>
                <div class="border-t border-foreground/10 pt-3 space-y-1.5">
                  <p class="text-xs text-muted-foreground"><strong class="text-foreground/70">@alex.creates</strong> GUIDE 🙏</p>
                  <p class="text-xs text-muted-foreground"><strong class="text-foreground/70">@priya_vids</strong> guide please!</p>
                  <p class="text-xs text-muted-foreground"><strong class="text-foreground/70">@zara.film</strong> GUIDE ✨</p>
                </div>
                <div class="flex items-center gap-2 pt-1">
                  <div class="size-2 rounded-full bg-primary animate-pulse"></div>
                  <p class="text-xs text-muted-foreground">3 DMs sent in the last 12 seconds</p>
                </div>
              </div>
            </div>
          </div>

          {/* Step 2 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="md:order-2">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">2</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">List Building</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Build your list in the background</h3>
              <p class="text-muted-foreground leading-relaxed">
                Collect emails and phone numbers right inside the DM conversation. No forms, no friction, no external landing pages. Followers share their details naturally, and every response gets saved to your contact list.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6 md:order-1">
              <p class="text-xs text-muted-foreground mb-4">DM conversation with @alex.creates</p>
              <div class="space-y-3 text-sm">
                <div class="flex gap-2">
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-xs text-foreground/70">YC</div>
                  <div class="bg-foreground/5 rounded-lg rounded-tl-none p-3 text-muted-foreground text-xs">
                    Hey Alex! Here's your free content calendar 🎉 → yourcreator.com/guide<br/><br/>
                    Want me to send weekly tips too? Drop your email and I'll add you to the list!
                  </div>
                </div>
                <div class="flex gap-2 justify-end">
                  <div class="bg-foreground/10 rounded-lg rounded-tr-none p-3 text-foreground text-xs">alex@gmail.com</div>
                  <div class="size-6 rounded-full bg-foreground/10 flex items-center justify-center shrink-0 mt-0.5 text-xs text-foreground/70">A</div>
                </div>
                <div class="flex items-center gap-2 pt-1 text-xs text-muted-foreground">
                  <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  Email captured and saved to contacts
                </div>
              </div>
            </div>
          </div>

          {/* Step 3 */}
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center size-8 rounded-full bg-foreground/10 text-foreground text-sm font-bold">3</span>
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Follow-ups</span>
              </div>
              <h3 class="text-xl font-semibold text-foreground mb-3">Follow-ups run themselves</h3>
              <p class="text-muted-foreground leading-relaxed">
                Set timed follow-up messages to re-engage anyone who didn't open your link. Announce your course, drop a reminder, share a bonus. Your funnel keeps running while you're filming your next piece.
              </p>
            </div>
            <div class="bg-card/80 ring-1 ring-foreground/10 rounded-2xl p-6">
              <p class="text-sm font-medium text-foreground mb-4">Follow-up sequence</p>
              <div class="space-y-3">
                <div class="flex items-start gap-3 p-3 rounded-lg bg-foreground/5">
                  <span class="text-xs text-muted-foreground w-14 shrink-0 pt-0.5">Instant</span>
                  <p class="text-muted-foreground text-xs">"Here's your free guide! Let me know if you have questions 📩"</p>
                </div>
                <div class="flex items-start gap-3 p-3 rounded-lg bg-foreground/5">
                  <span class="text-xs text-muted-foreground w-14 shrink-0 pt-0.5">Day 2</span>
                  <p class="text-muted-foreground text-xs">"Did you get a chance to go through it? Page 12 is the one everyone asks about 👀"</p>
                </div>
                <div class="flex items-start gap-3 p-3 rounded-lg bg-foreground/5">
                  <span class="text-xs text-muted-foreground w-14 shrink-0 pt-0.5">Day 5</span>
                  <p class="text-muted-foreground text-xs">"My full course drops Friday. Early access is open, want the link before it goes public?"</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

      {/* Use Cases */}
      <section class="py-14 border-b border-border">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-8">
          Key use cases
        </h2>
        <UseCases items={useCases} />
      </section>

      {/* FAQ */}
      <SolutionFaq items={faqs} />

      {/* Bottom CTA */}
    </div>

    <CtaBanner
      title="Your next post, your best lead gen."
      ctaText="Start building free"
      note="Set up in under 5 minutes. No credit card needed."
    />
  </main>
</Layout>
