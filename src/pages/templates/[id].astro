---
import Layout from "../../layouts/Layout.astro"
import { templates, triggerLabels, triggerColors } from "../../data/templates"
import type { Template } from "../../data/templates"

export function getStaticPaths() {
  return templates.map((t) => ({ params: { id: t.id } }))
}

const { id } = Astro.params
const template = templates.find((t) => t.id === id) as Template

const related = templates
  .filter((t) => t.id !== id && t.section === template.section)
  .slice(0, 3)

const color = triggerColors[template.automationMode]
const triggerLabel = triggerLabels[template.automationMode]
const appUrl = `https://app.botyoo.com/dashboard`

const triggerIcons: Record<string, string> = {
  COMMENT: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  STORY: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>`,
  DM: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.87 2 2 0 0 1 3.62 2.68h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17.3Z"/></svg>`,
  STORY_MENTION: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/></svg>`,
  SHARE: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>`,
  IG_LIVE: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14M19.07 4.93a10 10 0 0 1 0 14.14M7.76 7.76a6 6 0 0 0 0 8.49M16.24 7.76a6 6 0 0 1 0 8.49"/></svg>`,
  UNIVERSAL_COMMENT: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  CLICK_TO_DM: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>`,
}
const triggerIcon = triggerIcons[template.automationMode] ?? ""
---

<Layout
  title={`${template.name} - Botyoo Templates`}
  description={template.description}
>
  <main class="pt-28 pb-28">
    <div class="mx-auto max-w-5xl px-6">

      {/* Back */}
      <a href="/templates" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors mb-10">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
        All templates
      </a>

      {/* ── Header ── */}
      <div class="flex flex-col gap-5 pb-10 border-b">
        <div class="flex flex-wrap items-center gap-2.5">
          <span
            class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-semibold"
            style={`background:${color}14;color:${color}`}
            set:html={`${triggerIcon} ${triggerLabel}`}
          />
          {template.badge === 'flow-builder' ? (
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-violet-500">
              <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="6" height="4" rx="1"/><rect x="16" y="10" width="6" height="4" rx="1"/><rect x="2" y="18" width="6" height="4" rx="1"/><path d="M8 4h3a1 1 0 0 1 1 1v10a1 1 0 0 0 1 1h3"/><path d="M8 20h3a1 1 0 0 0 1-1v-3"/></svg>
              Flow Builder
            </span>
          ) : (
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-emerald-500">
              <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Instant
            </span>
          )}
          <span class="text-muted-foreground/40">·</span>
          <span class="text-[11px] font-medium text-muted-foreground">{template.section}</span>
        </div>

        <div>
          <h1 class="text-foreground text-3xl md:text-4xl font-semibold tracking-tight">
            {template.name}
          </h1>
          <p class="text-muted-foreground mt-3 text-lg leading-relaxed max-w-2xl">
            {template.description}
          </p>
        </div>

        <div class="flex flex-wrap items-center gap-3 mt-1">
          <a
            href={appUrl}
            class="btn btn-primary"
          >
            Get this template
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
          <span class="text-xs text-muted-foreground">Free · no card needed</span>
        </div>
      </div>

      {/* ── Body grid ── */}
      <div class="grid gap-12 lg:grid-cols-[1fr_300px] mt-12">

        {/* Left */}
        <div class="space-y-12 min-w-0">
          {template.about && (
            <section>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-4">Overview</h2>
              <p class="text-foreground text-base leading-relaxed">{template.about}</p>
            </section>
          )}

          <section>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5">How it works</h2>
            <ol class="relative space-y-6 before:absolute before:left-[15px] before:top-2 before:bottom-2 before:w-px before:bg-border">
              {[
                { label: 'Pick this template', desc: 'Open the Botyoo app and select this template from the library.' },
                { label: 'Customise your messages', desc: 'Edit the DM copy, add your link or lead magnet, and set your keywords.' },
                { label: 'Go live', desc: 'Activate the automation. Botyoo starts responding instantly, 24/7.' },
              ].map(({ label, desc }, i) => (
                <li class="relative flex items-start gap-4">
                  <div
                    class="relative z-10 flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-sm font-semibold ring-4 ring-background"
                    style={`background:${color}1a;color:${color}`}
                  >
                    {i + 1}
                  </div>
                  <div class="pt-0.5">
                    <p class="text-foreground font-medium text-sm">{label}</p>
                    <p class="text-muted-foreground text-sm mt-1 leading-relaxed">{desc}</p>
                  </div>
                </li>
              ))}
            </ol>
          </section>

          {template.tags.length > 0 && (
            <section>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-4">Tags</h2>
              <div class="flex flex-wrap gap-2">
                {template.tags.map((tag) => (
                  <span class="rounded-md bg-muted px-2.5 py-1 text-xs text-muted-foreground font-medium">#{tag}</span>
                ))}
              </div>
            </section>
          )}
        </div>

        {/* Right, details */}
        <aside class="space-y-8">
          <div class="lg:sticky lg:top-28 space-y-6">

            {/* Details */}
            <div>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-4">Details</h2>
              <dl class="space-y-3.5 text-sm">
                <div class="flex items-center justify-between gap-3">
                  <dt class="text-muted-foreground">Trigger</dt>
                  <dd class="font-medium" style={`color:${color}`}>{triggerLabel}</dd>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <dt class="text-muted-foreground">Type</dt>
                  <dd class="font-medium text-foreground">{template.badge === 'flow-builder' ? 'Flow Builder' : 'Instant'}</dd>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <dt class="text-muted-foreground">Category</dt>
                  <dd class="font-medium text-foreground text-right">{template.section}</dd>
                </div>
              </dl>
            </div>

            {template.bestFor && template.bestFor.length > 0 && (
              <div class="pt-5 border-t">
                <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-3">Best for</h2>
                <div class="flex flex-wrap gap-1.5">
                  {template.bestFor.map((b) => (
                    <span class="rounded-full bg-muted px-2.5 py-1 text-xs font-medium text-muted-foreground">{b}</span>
                  ))}
                </div>
              </div>
            )}

            <div class="pt-5 border-t flex items-center gap-2.5">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
              </div>
              <div>
                <p class="text-foreground text-xs font-medium">By Botyoo</p>
                <p class="text-muted-foreground text-[11px]">Meta Tech Provider</p>
              </div>
            </div>
          </div>
        </aside>
      </div>

      {/* ── Related ── */}
      {related.length > 0 && (
        <div class="mt-24 border-t pt-12">
          <div class="flex items-center gap-2 mb-5">
            <span class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">More in {template.section}</span>
          </div>
          <div class="border rounded-xl overflow-hidden">
            <div class="grid grid-cols-1 sm:grid-cols-3">
              {related.map((t, i) => {
                const c = triggerColors[t.automationMode]
                const lbl = triggerLabels[t.automationMode]
                const ic = triggerIcons[t.automationMode] ?? ""
                return (
                  <a
                    href={`/templates/${t.id}`}
                    class={`group flex flex-col gap-4 bg-background p-5 transition-colors duration-150 hover:bg-card ${i > 0 ? 'border-t sm:border-t-0 sm:border-l border-border' : ''}`}
                  >
                    <div class="flex items-center justify-between">
                      <span
                        class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-semibold"
                        style={`background:${c}14;color:${c}`}
                        set:html={`${ic} ${lbl}`}
                      />
                      <svg class="text-muted-foreground/30 group-hover:text-foreground/50 transition-colors w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
                    </div>
                    <div>
                      <h3 class="text-foreground text-sm font-semibold leading-snug group-hover:text-primary transition-colors">{t.name}</h3>
                      <p class="text-muted-foreground mt-1.5 text-xs leading-relaxed line-clamp-2">{t.description}</p>
                    </div>
                  </a>
                )
              })}
            </div>
          </div>
        </div>
      )}

    </div>
  </main>
</Layout>
