---
import Layout from "../../layouts/Layout.astro"
import { templates, sections, triggerLabels, triggerColors } from "../../data/templates"

const triggerIcons: Record<string, string> = {
  COMMENT: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  STORY: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>`,
  DM: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.87 2 2 0 0 1 3.62 2.68h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17.3Z"/></svg>`,
  STORY_MENTION: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/></svg>`,
  SHARE: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>`,
  IG_LIVE: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14M19.07 4.93a10 10 0 0 1 0 14.14M7.76 7.76a6 6 0 0 0 0 8.49M16.24 7.76a6 6 0 0 1 0 8.49"/></svg>`,
  UNIVERSAL_COMMENT: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  CLICK_TO_DM: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>`,
}

const totalCount = templates.length
---

<Layout
  title="Templates: Botyoo"
  description="Ready-made Instagram DM automation templates. Pick one, customise the messages, go live in minutes."
>
  <main class="pt-28 pb-32">
    <div class="mx-auto max-w-6xl px-6">

      {/* Hero */}
      <div class="mb-16">
        <p class="text-muted-foreground text-sm mb-3 tabular-nums">{totalCount} templates</p>
        <h1 class="text-foreground text-4xl font-semibold tracking-tight md:text-5xl max-w-xl leading-tight">
          Automation templates<br />that actually work
        </h1>
        <p class="text-muted-foreground mt-4 max-w-md text-base leading-relaxed">
          Real flows for creators, coaches, and brands. Pick one,
          swap in your copy, and go live, takes about 3 minutes.
        </p>
      </div>

      {/* Filter tabs */}
      <div class="mb-10 flex flex-wrap gap-1.5" id="filter-bar" role="tablist">
        {["All", ...sections].map((s, i) => (
          <button
            type="button"
            role="tab"
            data-filter={i === 0 ? "all" : s}
            data-active={i === 0 ? "true" : "false"}
            class="filter-btn px-3.5 py-1.5 rounded-md text-sm font-medium transition-all cursor-pointer
              data-[active=true]:bg-foreground data-[active=true]:text-background
              data-[active=false]:text-muted-foreground data-[active=false]:hover:text-foreground data-[active=false]:hover:bg-foreground/6"
          >
            {s}
          </button>
        ))}
      </div>

      {/* Grid, grouped by section */}
      <div id="template-grid" class="space-y-10">
        {sections.map((section) => {
          const sectionTemplates = templates.filter((t) => t.section === section)
          if (!sectionTemplates.length) return null
          return (
            <div data-section={section} class="section-group">
              {/* Section label */}
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">{section}</span>
                <span class="text-xs text-muted-foreground/40">{sectionTemplates.length}</span>
              </div>

              {/* Card list, no grid, just stacked rows with inline dividers */}
              <div class="border rounded-xl overflow-hidden divide-y divide-border">
                {(() => {
                  // Chunk into rows of 3
                  const rows: (typeof sectionTemplates)[] = []
                  for (let i = 0; i < sectionTemplates.length; i += 3) {
                    rows.push(sectionTemplates.slice(i, i + 3))
                  }
                  return rows.map((row, rowIdx) => (
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                      {row.map((t, colIdx) => {
                        const color = triggerColors[t.automationMode]
                        const label = triggerLabels[t.automationMode]
                        const icon = triggerIcons[t.automationMode] ?? ""
                        const addLeftBorder = colIdx > 0
                        return (
                          <a
                            href={`/templates/${t.id}`}
                            data-template-section={t.section}
                            class={`template-card group flex flex-col gap-4 bg-background p-5 transition-colors duration-150 hover:bg-card ${addLeftBorder ? 'border-l border-border' : ''}`}
                          >
                            {/* Trigger chip + arrow */}
                            <div class="flex items-center justify-between">
                              <span
                                class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-semibold"
                                style={`background:${color}14;color:${color}`}
                                set:html={`${icon} ${label}`}
                              />
                              <svg class="text-muted-foreground/30 group-hover:text-foreground/50 transition-colors w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                              </svg>
                            </div>

                            {/* Name + description */}
                            <div>
                              <h3 class="text-foreground text-sm font-semibold leading-snug group-hover:text-primary transition-colors">
                                {t.name}
                              </h3>
                              <p class="text-muted-foreground mt-1.5 text-xs leading-relaxed line-clamp-2">
                                {t.description}
                              </p>
                            </div>

                            {/* Footer badge */}
                            <div class="mt-auto">
                              {t.badge === 'flow-builder' ? (
                                <span class="inline-flex items-center gap-1 text-[10px] font-medium text-violet-500/80">
                                  <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="6" height="4" rx="1"/><rect x="16" y="10" width="6" height="4" rx="1"/><rect x="2" y="18" width="6" height="4" rx="1"/><path d="M8 4h3a1 1 0 0 1 1 1v10a1 1 0 0 0 1 1h3"/><path d="M8 20h3a1 1 0 0 0 1-1v-3"/></svg>
                                  Flow Builder
                                </span>
                              ) : (
                                <span class="inline-flex items-center gap-1 text-[10px] font-medium text-emerald-500/80">
                                  <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                                  Instant
                                </span>
                              )}
                            </div>
                          </a>
                        )
                      })}
                    </div>
                  ))
                })()}
              </div>
            </div>
          )
        })}
      </div>

      {/* Empty state */}
      <div id="empty-state" class="hidden py-20 text-center text-muted-foreground text-sm">
        Nothing here yet.
      </div>

      {/* Bottom CTA */}
      <div class="mt-20 border-t pt-14 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <p class="text-foreground text-lg font-semibold">Don't see what you need?</p>
          <p class="text-muted-foreground text-sm mt-1 max-w-sm">
            Every template is a starting point. Open the Flow Builder and build exactly what you need.
          </p>
        </div>
        <a
          href="https://app.botyoo.com/dashboard"
          class="btn btn-primary shrink-0"
        >
          Start building free
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>

    </div>
  </main>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const groups  = document.querySelectorAll<HTMLElement>('.section-group')
  const empty   = document.getElementById('empty-state')

  function setFilter(filter: string) {
    buttons.forEach(b => { b.dataset.active = b.dataset.filter === filter ? 'true' : 'false' })
    let any = false
    groups.forEach(g => {
      const show = filter === 'all' || g.dataset.section === filter
      g.classList.toggle('hidden', !show)
      if (show) any = true
    })
    empty?.classList.toggle('hidden', any)
  }

  buttons.forEach(b => b.addEventListener('click', () => setFilter(b.dataset.filter ?? 'all')))
</script>
